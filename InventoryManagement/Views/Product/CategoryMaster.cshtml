                                <img src="@Model.ImagePath" name="ProductImage" id="ProductImage" class="form-control col-md-7 col-xs-12" style="height:158px;width:30%" />
                               
                            </div>
                            
                            <input type="file" id="upload" name="upload" style="visibility: hidden; width: 1px; height: 1px" />
                            <a href="" onclick="document.getElementById('upload').click();return false" id="UpdateImage" style="margin-left: 26%;">Update Image<span style="color:red">&nbsp;(Image Size Limit:400x400)</span></a>
                        </div>
                       
                        <div class="form-group">
