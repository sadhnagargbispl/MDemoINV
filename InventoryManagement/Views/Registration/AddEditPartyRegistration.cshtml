                                        else
                                        {  @Html.TextBoxFor(m => m.objUserDetails.Password, new
                                      {
                                          id = "Password",
                                          type = "password",
                                          tabindex = "0",
                                          @required = "required",
                                          name = "Password",
                                          maxlength = "50",
                                          @class = "form-control",
                                          autocomplete = "off",
                                          onfocus = "this.removeAttribute('readonly');"
                                      })}
                                    </div>
                                </div>
