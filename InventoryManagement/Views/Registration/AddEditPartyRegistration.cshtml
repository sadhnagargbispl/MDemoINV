    /* ==========================
     LOAD PARENT PARTY (FILTERED)
  ========================== */
    function GetParentPartyList(GroupId) {

        var StateCode = $("#hiddenStateCode").val();

        $.ajax({
            url: '/Registration/GetParentPartyList',
            dataType: 'JSON',
            method: 'GET',
            data: {
                GroupId: GroupId,
                StateCode: StateCode
            },
            success: function (data) {

                $("#ParentPartyCode").empty();

                if (data.length > 0) {

                    $("#hiddenParentPartyCode").val(data[0].PartyCode);

                    $.each(data, function (i, item) {
                        $("#ParentPartyCode").append(
                            "<option value='" + item.PartyCode + "'>" +
                            item.PartyName + "</option>"
                        );
                    });

                    GetPartyCode();
                }
                else {
                    OpenDialog("dialogMessage", "No Parent Party found for selected State!", "false");
                }
            }
        });
    }
    function GetPartyCode() {
        debugger;
        var SelectedParentPartyCode = $("#hiddenParentPartyCode").val();
        var SelectedGroupId = $("#hiddenGroupId").val();
        $.ajax({
            url: '/Registration/GetPartyCodeStr',
            dataType: 'JSON',
            method: 'GET',
            data: { 'SelectedParentPartyCode': SelectedParentPartyCode, 'SelectedGroupId': SelectedGroupId },
            success: function (data) {
                console.log("data party code:", data);
                //response(data);
                if (ActionType == "Add") {
                    $("#UserName").val(data);
                    $("#PartyCode").val(data);
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }
    function CheckDuplicateUsername() {
        var UserNameStr = $("#UserName").val();
        var PartyCodeStr = $("#PartyCode").val();
        var IsActionType = ActionType;
        $.ajax({
            url: '/Registration/IsDuplicatePartyUserName',
            dataType: 'JSON',
            method: 'GET',
            data: { 'IsActionType': IsActionType, 'PartyCode': PartyCodeStr, 'UserName': UserNameStr },
            success: function (data) {
                console.log("data:", data);
                //response(data);
                if (data.ResponseStatus == "FAILED") {
                    DuplicateUsername = true;
                    if (UserNameStr == "") {

                    }
                    else {
                        OpenDialog("dialogMessage", "Please try different username!", "false");
                    }
                }
                else {
                    DuplicateUsername = false;
                }


            },
            error: function (error) {
                console.log(error);
            }
        });
    }

    function CheckDuplicateUserPartyCode() {
        var UserPartyCode = $("#UserPartyCode").val();
        var PartyCodeStr = $("#PartyCode").val();
        var IsActionType = ActionType;
        if (UserPartyCode != '') {
            $.ajax({
                url: '/Registration/IsDuplicatePartyUserPartycode',
                dataType: 'JSON',
                method: 'GET',
                data: { 'IsActionType': IsActionType, 'PartyCode': PartyCodeStr, 'UserPartycode': UserPartyCode },
                success: function (objResult) {
                    console.log("data:", objResult);
                    //response(data);
                    if (objResult.length != 0) {
                        DuplicateUserPartyCode = true;
                        console.log(DuplicateUserPartyCode);
                        $("#UserPartyCode").val('');
                        OpenDialog("dialogMessage", "This code is already exist!", "false");
                    }
                    else {
                        DuplicateUserPartyCode = false;
                    }
                },
                error: function (error) {
                    console.log("error:", error);
                }
            });
        }
    }
    function GetAllCity() {
        $.ajax({
            url: '/Registration/GetAllCities',
            dataType: 'JSON',
            method: 'GET',
            //data: { 'LedgerName': '' },
            success: function (data) {
                console.log("data:", data);
                //response(data);
                CityList = data;
            },
            error: function (error) {
                console.log(error);
            }
        });
    }
    function GetCity(StateId) {
        $("#CityCode").empty();
        var flag = 0;
        for (var i = 0; i < CityList.length; i++) {
            if (parseFloat(CityList[i].StateCode) == parseFloat(StateId)) {
                if (flag == 0) {
                    flag = 1;
                    $("#hiddenCityCode").val(CityList[i].CityCode);
                    $("#hiddenCityName").val(CityList[i].CityName);
                }
                $("#CityCode").append("<option value=" + CityList[i].CityCode + ">" + CityList[i].CityName + "</option>");
            }
        }
    }
    function OpenDialog(dialogId, Message, isConfirmation) {
        $("#" + dialogId).empty();
        $("#" + dialogId).append('<p>' + Message + '</p>');
        if (isConfirmation == "true") {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "Yes",
                    id: "btnYes" + dialogId,
                    click: function () {
                        //var isOpen = $("#dialog").dialog("isOpen");
                        //if (isOpen == true) {
                        //    okCallBack();
                        //}
                        IsYes = true;
                        $("#" + dialogId).dialog("close");


                    }
                },
                {
                    text: "No",
                    id: "btnNo" + dialogId,
                    click: function () {
                        //var isOpen = $("#dialog").dialog("isOpen");
                        //if (isOpen == true) {
                        //    okCallBack();
                        //}
                        IsYes = false;
                        $("#" + dialogId).dialog("close");
                    }
                }
                ]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }
        else {


            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btn" + dialogId,
                    click: function () {
                        //var isOpen = $("#dialog").dialog("isOpen");
                        //if (isOpen == true) {
                        //    okCallBack();
                        //}

                        $("#" + dialogId).dialog("close");


                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }

    }

    function GetCustomerInfo(IdNo) {
        //if (IdNo != "" && IdNo != null) {
        //    IdNo = parseInt(IdNo);

        $.ajax({
            url: '@Url.Action("GetCustInfo", "Transaction")',
            type: 'POST',
            data: { "IdNo": IdNo },

            dataType: "json",
            success: function (objResult) {
                if (objResult != null) {
                    if (objResult.Name == "") {
                        OpenDialog("dialogMessage", "Record does not exists.", "false");
                        $("#UserPartyCode").val('');
                    }
                    else {

                        $("#CityName").val(objResult.CityName);
                        $("#StateCode").val(objResult.StateCode);
                        $("#MobileNo").val(objResult.MobileNo);
                    }
                }
                else {
                    $("#CityName").val('');
                    $("#StateCode").val('');
                    $("#MobileNo").val('');

                }
            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });

    }
</script>

