                uiLibrary: 'bootstrap',
                headerFilter: true,
                columns: [
                    { field: 'SNo', width: 80, title: 'S.No.', sortable: true, hidden: false, filterable: true },
                    { field: 'PartyCode', width: 100, title: '@PartyCaption Code', sortable: true, hidden: false, filterable: true },
                    { field: 'PartyName', width: 150, title: '@PartyCaption Name', sortable: true, hidden: false, filterable: true },
                    { field: 'Category', width: 100, title: 'Category', sortable: true, hidden: false, filterable: true },
                    { field: 'ProductCode', width: 80, title: 'Code', sortable: true, hidden: false, filterable: true },
                    { field: 'ProductName', width: 150, title: 'Product Name', sortable: true, hidden: false, filterable: true },
                    { field: 'BatchNo', width: 100, title: 'Batch No.', sortable: true, hidden: false, filterable: true },
                    //{ field: 'Barcode', width: 100, title: 'Barcode', sortable: true, hidden: false, filterable: true },
                    { field: 'BarcodeStatus', width: 100, title: 'Barcode Status', renderer: function (value, record) { return (value == "Y") ? "Active" : "Inactive"; }, sortable: true, hidden: true, filterable: true },
                    { field: 'StockIn', width: 80, title: 'Stock In', sortable: true, hidden: dispayInOut, filterable: true },
                    { field: 'StockOut', width: 80, title: 'Stock Out', sortable: true, hidden: dispayInOut, filterable: true },
                    { field: 'Qty', width: 80, title: 'Stock Balance', sortable: true, hidden: false, filterable: true },
                    { field: 'PurchaseRate', width: 100, title: 'Pu.Rate', sortable: true, hidden: false, filterable: true },
                    { field: 'RateOrDP', width: 80, title: 'DP', sortable: true, hidden: false, filterable: true },
                    { field: 'MRP', width: 80, title: 'MRP', sortable: true, hidden: false, filterable: true },
                    { field: 'BV', title: 'BV', width: 80, sortable: true, hidden: false, filterable: true },
                    { field: 'PV', title: 'PV', width: 80, sortable: true, hidden: false, filterable: true },
                    //{ field: 'StockValue', title: 'Stock Value', sortable: true, hidden: false, filterable: true },
                    { field: 'DPStockValue', width: 80, title: '(DP)Stock Value', sortable: true, hidden: false, filterable: true },
                    { field: 'MRPSTockValue', width: 80, title: '(MRP)STock Value', sortable: true, hidden: false, filterable: true },
                ],
                pager: { limit: 100, sizes: [15, 20, 35, 50, 65, 80, 95, 100] },
                rowDataBound: function (e, $row, id, record) {
                    if (parseFloat(record.Qty) === 0) {
                        $row.css('color', '#A52A2A');
                    }
                },
                dataBound: function (e, records, totalRecords) {
                    debugger;
                    if ('@LoginuserType' === "shoppe") {
                        $("#totalstockIn").html(TotalStockIn);
                        $("#totalstockOut").html(TotalStockout);
                    }
                    $("#totalstockBalance").html(TotalStockbalance);
                    $("#totalstockRCPValue").html(NetTotal);
                    $("#totalbv").html(TotatalBV);
                    $("#totalpv").html(TotalPV.toFixed(2));
                    $("#totalmrp").html(TotalValueMRP);
                    $("#totalPURate").html(TotalPurate);
                    $("#totalMP").html(TotalMRP);

                }
            });


        }

        $(".loader").hide();
    }

    function GetStockDetails(CategoryCode, ProductCode, PartyCode, IsBatchWise, StockType) {
        if (CategoryCode == "" || CategoryCode == null || ProductCode == "" || ProductCode == null) {
            if (CategoryCode == "") {
                CategoryCode = 0;
                // OpenDialog("dialogMessage", "Please enter category!", "false");
            }
            if (ProductCode == "") {
                ProductCode = 0;
                // OpenDialog("dialogMessage", "Please enter product!", "false");
                //else
                //    OpenDialog("dialogMessage", "Please enter party!", "false");
            }
        }
        TotalStockIn = 0;
        TotalStockout = 0;
        TotalStockbalance = 0;
 NetTotal = 0;
 TotatalBV = 0;
 TotalPV = 0;
 TotalValueMRP = 0;
 TotalDP = 0;
 TotalMRP = 0;
 TotalPurate = 0;
        NetTotal = 0;
        $.ajax({
            url: '@Url.Action("GetStockReport", "Report")',
            type: 'POST',
            data: { "CategoryCode": CategoryCode, "ProductCode": ProductCode, "PartyCode": PartyCode, "IsBatchWise": IsBatchWise, "StockType": StockType },

            dataType: "json",
            success: function (objResult) {
                StockGrid = [{}];
                if (objResult.length > 0) {

                    StockGrid = StockGrid.splice(1);
                    for (var i = 0; i < objResult.length; i++) {

                        if (objResult[i].ExpDate != "") {
                            var dateObj = new Date(objResult[i].ExpDateD.match(/\d+/)[0] * 1);
                            var ExpD = (dateObj.getDate()) + "/" + (dateObj.getMonth() + 1) + "/" + dateObj.getFullYear();
                            dateObj = new Date(objResult[i].MfgDateD.match(/\d+/)[0] * 1);
                            var MfgD = (dateObj.getDate()) + "/" + (dateObj.getMonth() + 1) + "/" + dateObj.getFullYear();

                            StockGrid.push({
                                "SNo": i + 1, "PartyCode": objResult[i].PartyCode, "PartyName": objResult[i].PartyName,
                                "Category": objResult[i].Category, "ProductCode": objResult[i].ProductCode,
                                "ProductName": objResult[i].ProductName, "RateOrDP": objResult[i].RateOrDP, "MRP": objResult[i].MRP,
                                "Qty": objResult[i].Qty, "StockValue": objResult[i].StockValue, "DPStockValue": objResult[i].DPStockValue,
                                "MRPSTockValue": objResult[i].MRPSTockValue, "BatchNo": objResult[i].BatchNo,
                                "BarcodeStatus": objResult[i].BarcodeStatus,
                                "Expired": objResult[i].Expired, "ExpDate": ExpD, "MfgDate": MfgD, "StockIn": objResult[i].InStock,
                                "StockOut": objResult[i].OutStock, "OpeningStock": objResult[i].openingStock, "PurchaseRate": objResult[i].PurchaseRate,
                                "PV": objResult[i].PV, "BV": objResult[i].BV
                            });
                        }
                        else {
                            StockGrid.push({
                                "SNo": i + 1, "PartyCode": objResult[i].PartyCode, "PartyName": objResult[i].PartyName,
                                "Category": objResult[i].Category, "ProductCode": objResult[i].ProductCode, "ProductName": objResult[i].ProductName,
                                "RateOrDP": objResult[i].RateOrDP, "MRP": objResult[i].MRP, "Qty": objResult[i].Qty, "StockValue": objResult[i].StockValue,
                                "DPStockValue": objResult[i].DPStockValue, "MRPSTockValue": objResult[i].MRPSTockValue, "BatchNo": objResult[i].BatchNo,
                                "BarcodeStatus": objResult[i].BarcodeStatus,  "Expired": objResult[i].Expired,
                                "ExpDate": objResult[i].ExpDate, "MfgDate": objResult[i].MfgDate, "StockIn": objResult[i].InStock,
                                "StockOut": objResult[i].OutStock, "OpeningStock": objResult[i].openingStock, "PurchaseRate": objResult[i].PurchaseRate,
                                "PV": objResult[i].PV, "BV": objResult[i].BV
                            });
                        }

                        TotalStockIn += parseFloat(objResult[i].InStock);
                        TotalStockout += parseFloat(objResult[i].OutStock);
                        TotalStockbalance += parseFloat(objResult[i].Qty);
                        NetTotal += parseFloat(objResult[i].DPStockValue);
                        TotatalBV += parseFloat(objResult[i].BV);
                        TotalPV += parseFloat(objResult[i].PV);
                        TotalValueMRP += parseFloat(objResult[i].MRPSTockValue);
                        TotalDP += parseFloat(objResult[i].RateOrDP);
                        TotalMRP += parseFloat(objResult[i].MRP);
                        TotalPurate += parseFloat(objResult[i].PurchaseRate);

                    }
                    tableStockGrid = StockGrid;


                    $("#noRecord").hide();

                }
                else {

                    $("#noRecord").show();
                }
                fillGrid();
                $(".preloader").hide();

            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });



    }
</script>

