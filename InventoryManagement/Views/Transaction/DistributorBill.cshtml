        // ===== BANK DEPOSIT (BD) SECTION =====
        function UpdatePaymode(paymode, enteredValue, textboxId) {
            debugger;
            enteredValue = safeParse(enteredValue);
            var found = false;

            for (var i = 0; i < LatestAmountEnteresdInPayMode.length; i++) {
                if (LatestAmountEnteresdInPayMode[i].Paymode === paymode) {
                    LatestAmountEnteresdInPayMode[i].Amount = enteredValue;
                    found = true;
                    break;
                }
            }
            if (!found) {
                LatestAmountEnteresdInPayMode.push({ "Paymode": paymode, "Amount": enteredValue });
            }

            RecalculateCashAmount(textboxId);
        }

        function RecalculateCashAmount(lastTextboxId) {
            debugger;
            var totalAmount = safeParse($("#TotalAmountNet").val());
            var totalEntered = 0;

            for (var i = 0; i < LatestAmountEnteresdInPayMode.length; i++) {
                totalEntered += safeParse(LatestAmountEnteresdInPayMode[i].Amount);
            }

            // prevent total paymodes > total bill
            if (totalEntered > totalAmount) {
                showError("Total payment amount cannot exceed the bill amount!");

                // last textbox reset karo
                if (lastTextboxId) {
                    $("#" + lastTextboxId).val(0);
                }

                // last paymode reset karo
                if (LatestAmountEnteresdInPayMode.length > 0) {
                    LatestAmountEnteresdInPayMode[LatestAmountEnteresdInPayMode.length - 1].Amount = 0;
                }

                // recalc after reset
                totalEntered = 0;
                for (var j = 0; j < LatestAmountEnteresdInPayMode.length; j++) {
                    totalEntered += safeParse(LatestAmountEnteresdInPayMode[j].Amount);
                }
            } else {
                clearError();
            }

            //let hasCalc = ProductGrid.some(x => x.IsCalc === true);
            //debugger;
            //if (hasCalc == true) {
            //    var aftertotal =
            //       aftertotal =
            //        parseFloat($("#AmountByBD").val() || 0) +
            //        parseFloat($("#AmountByCard").val() || 0);
            //    //$("#CashAmount").val(NetAmounPayable - aftertotal);
            //}
            //else {
            //    //$("#CashAmount").val(NetAmounPayable);
            //}

            var cash = totalAmount - totalEntered;
            if (cash < 0) cash = 0;

            $("#CashAmount").val(cash.toFixed(2));
            $("#TotalPaymodeAmt").val(totalEntered.toFixed(2));
        }
