                        console.log("ProductGrid[i].Amount", parseFloat(ProductGrid[i].Amount));
                        TotalSumAmount += parseFloat(ProductGrid[i].Amount);
                        TotalDisc += parseFloat(ProductGrid[i].DiscAmt);
                        TotalTaxtAmt += parseFloat(ProductGrid[i].TaxAmt);
