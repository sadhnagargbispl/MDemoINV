        $("#BillCalculation").click(function (e) {
            debugger;
            if (ProductGrid.length <= 0) {
                alert("Please select atleast one product");
                $('#IsV').prop('checked', false);
                return false;
            }
            //first we set amount by voucher-------------- 
            var totalfpvBalance = parseFloat($("#vamt").val()) || 0;
            var FPVBalance = parseFloat($("#vamt").val()) || 0;
            if (totalfpvBalance === 0)
            {
                alert("You currently have no FPV balance available to apply to this order.");
                return false;
            }
            var TotalAmountNet = $("#TotalAmountNet").val();
             // Get Bill Amount
            var totalBill = parseFloat(TotalAmountNet) || 0;
            // User FPV Balance
           var totalfpvBalance = parseFloat(FPVBalance) || 0;
           // Max FPV allowed based on bill
           var allowedFPV = Math.floor(totalBill / 2);
           // Final usable FPV
            var finalFPV = Math.min(totalfpvBalance, allowedFPV);
              if (totalBill < (finalFPV * 2)) {
                    alert("Discount applicable only on orders above 2000.");
                   //$('#IsV').prop('checked', false);
                   return false;
              }
            //if (TotalAmountNet < 2000) {
            //    alert("Discount applicable only on orders above 2000.");
            //    // $('#IsV').prop('checked', false);
            //    return false;
            //}
            
            ////Get Bill Amount
            //var totalBill = parseFloat(TotalAmountNet) || 0;
            //// Calculate allowed FPV (every 2000 → 1000)
            //var allowedFPV = Math.floor(totalBill / 2000) * 1000;
            ////Final usable FPV = min(balance, allowed)
            //var finalFPV = Math.min(totalfpvBalance, allowedFPV);

            if (finalFPV > 0) {
                $("#hidfpamt").val(finalFPV);
                $("#AmountByVoucher").val(finalFPV);
            } else {
                $("#hidfpamt").val('0');
                $("#AmountByVoucher").val('0');
            }
            //---------------------------------------------

            var FpvAmount = $("#AmountByVoucher").val();
            if (FpvAmount == "" || FpvAmount == null) {
                FpvAmount = "0";
            }
            var Couponamount = $("#AmountbyCoupon").val();
            if (Couponamount == "" || Couponamount == null) {
                Couponamount = "0";
            }
            var Totaladjustamount = parseFloat(FpvAmount) + parseFloat(Couponamount);

            if (Totaladjustamount == 0) {
                alert("Please select FPV or Coupon for calculation");
                return false;
            }
            var passwvarify = $("#passwvarify").val();
            if (passwvarify == "false") {
                alert("Please varify user.");
                $("#userpassw").focus();
                return false;
            }
            var DiscPer = 0;
            var totalDP = ProductGrid.reduce(function (sum, item) {
                var dp = parseFloat(item.DP);
                var qty = parseFloat(item.Qty);
                dp = isNaN(dp) ? 0 : dp;
                qty = isNaN(qty) ? 0 : qty;
                return sum + (dp * qty);
            }, 0);
            var DiscPer = (Totaladjustamount / (parseFloat(totalDP))) * 100;
            DiscPer = parseFloat(DiscPer).toFixed(2);
            for (i = 0; i < ProductGrid.length; i++) {
                if (ProductGrid[i].SNo != "") {
                    //if (DiscPer == 0) {
                    //    var DiscPer = (Totaladjustamount / (parseFloat(ProductGrid[i].DP) * parseFloat(ProductGrid[i].Qty))) * 100;
                    //    DiscPer = parseFloat(DiscPer).toFixed(2);
                    //}
                    ProductGrid[i].DiscPer = parseFloat(DiscPer);
                    var DiscountAmt = (parseFloat(ProductGrid[i].DP) * parseFloat(ProductGrid[i].Qty)) * (parseFloat(DiscPer) / 100);
                    DiscountAmt = parseFloat(DiscountAmt).toFixed(2);
                    ProductGrid[i].DiscAmt = DiscountAmt;
                    var NETDP = parseFloat(ProductGrid[i].DP) - (ProductGrid[i].DP * (DiscPer / 100));
                    NETDP = parseFloat(NETDP).toFixed(2);
                    var TaxPer = parseFloat(ProductGrid[i].TaxPer) / 100;
                    var Price = ((NETDP * ProductGrid[i].Qty) * 100) / (parseFloat(ProductGrid[i].TaxPer) + 100);
                    Price = parseFloat(Price).toFixed();
                    var Taxamount = parseFloat(Price) * TaxPer;
                    var finalamount = NETDP * ProductGrid[i].Qty;
                    finalamount = parseFloat(finalamount).toFixed(2);
                    // var Amount=ProductGrid[i].DP-Taxamount;
                    // ProductGrid[i].Amount=Amount.toFixed(2);
                    ProductGrid[i].TaxAmt = Taxamount.toFixed(2);
                    ProductGrid[i].TotalAmount = finalamount;
                    ProductGrid[i].NETDP = NETDP;
                    ProductGrid[i].Price = Price;
                    ProductGrid[i].IsCalc = true;
                    ProductGrid[i].Rate = Price;
                    ProductGrid[i].Amount = Price;
                    //var tempbv = parseFloat(ProductGrid[i].BV) / 2;
                    //ProductGrid[i].BV = tempbv;
                    //ProductGrid[i].BVValue = tempbv * parseFloat(ProductGrid[i].Qty);
                    if ($('#IsCU').is(":checked")) {
                        ProductGrid[i].IsCoupon = "Yes";
                    }
                    if ($('#IsV').is(":checked")) {
                        ProductGrid[i].IsFpv = "Yes";
                    }
                }
            }
            fillGrid();
            CalculateTotals();

            var totaladfp = parseFloat($("#AmountByVoucher").val()) || 0;
            var totalBVValue = parseFloat($("#TotalBV").val()) || 0;
            if (totaladfp > 0) {
                var calculated = totalBVValue - (totaladfp / 2);
                // Prevent negative value
                $("#TotalAdBV").val(Math.max(0, calculated));
            } else {
                $("#TotalAdBV").val(totalBVValue);
            }
            //OpenPayModePopup();
        });
