                                for (var i = 0; i < confPlist.length; i++) {
                                    console.log(confPlist[i]);
                                    var confProd = confPlist[i].split("~");
                                    GetProductInfo("P", confProd[0], true, confPQtylist[i]);

                                    // GetProductInfo(isProductSearch, data, offerProduct, offerQty)
                                    DoCalculation(true);
                                    $("#AddRecordInGrid").click();
                                    if (ProductGrid.length > 0) {
                                        var ListObjStr = JSON.stringify(ProductGrid);
                                        $("#ListObjHidden").val(ListObjStr);
                                        formdata = new FormData($("#distributorForm")[0]);
                                        console.log("done..");
                                    }
                                }
                                $("#ProductName").val('')
                                $("#ProductName").focus();
                            }

                            var plist = offerdetail[2].split(",");
                            if (plist.length == 1) {
                                var FreeProd = offerdetail[2].split("~");
                                GetProductInfo("P", FreeProd[0], true, offerdetail[3]);
                                DoCalculation(true);
                                $("#AddRecordInGrid").click();
                                if (ProductGrid.length > 0) {
                                    var ListObjStr = JSON.stringify(ProductGrid);
                                    $("#ListObjHidden").val(ListObjStr);
                                    formdata = new FormData($("#distributorForm")[0]);
                                    console.log("done");
                                }
                                if (StockError == false) {
                                    SaveBill();
                                }
                                else {
                                    OfferOutOfStock();
                                }
                            }
                            else {
                                for (var i = 0; i < plist.length; i++) {
                                    var plistitem = plist[i].split("~");
                                    $("#products").append("<label class='col-lg-6'><input type='radio' data-qty='" + offerdetail[3] + "' class='freeproduct' name='freeproduct' value='" + plistitem[0] + "'>" + plistitem[0] + "</label>");
                                }

                                $("#dialogOffer").dialog({
                                    modal: true,
                                    width: "55%"
                                });
                            }

                        }
                        else {
                            if (StockError == false) {
                                SaveBill();
                            }
                        }
                    }
                    else {
                        if (StockError == false) {
                            SaveBill();
                        }
                    }
                },
