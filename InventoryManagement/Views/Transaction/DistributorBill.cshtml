    function lockoutSubmit() {

        var button = $("#ResendOTP");
        var oldValue = $('#ResendOTP').text();
        setTimeout(function () {
            button.attr('disabled', true);
            $('#ResendOTP').text('Wait 45 sec');
        }, 0);

        var i = 45;

        setInterval(function () {
            if (i > 0) {
                $("#ResendOTP").text('Wait ' + i + ' sec...');
                i--;
            }
        }, 1000);

        setTimeout(function () {
            $('#ResendOTP').text(oldValue);
            button.attr('disabled', false);
            i = 0;
        }, 45000);
    }



    function GetOfferProds() {
        var OfferType = parseFloat($("#OfferType").val());

        $.ajax({
            url: '/Transaction/GetOfferProductNamesOnly',
            dataType: 'JSON',
            method: 'GET',
            data: { 'OfferID': SelectedOfferID, 'type': OfferType },
            success: function (data) {
                console.log("data:", data);
                OfferItemList = [];
                OfferItemListDetail = [];
                if (data != null) {
                    var i = 0;
                    for (i = 0; i < data.length; i++) {
                        OfferItemListDetail.push(data[i]);
                        OfferItemList.push(data[i].ProdName);
                    }
                }

            },
            error: function (error) {
                console.log(error);
            }
        });
    }

    function GetOfferBuyProducts() {
        $.ajax({
            url: '/Transaction/GetOfferBuyProducts',
            dataType: 'JSON',
            method: 'GET',
            async: false,
            data: { 'OfferID': SelectedOfferID },
            success: function (data) {
                BuyOfferItemList = [];
                if (data != null) {
                    var i = 0;
                    for (i = 0; i < data.length; i++) {
                        BuyOfferItemList.push(data[i]);
                    }
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }
    function Disablepaymode() {
        var SelectedInvoiceType = $("#SelectedInvoiceType").val();
        if (SelectedInvoiceType == "PV") {
            $("#PaymodePopup").attr("disabled", true);
            $("#Paymodediv").hide();
            $("#passworddiv").hide();
            $("#BillCalculation").attr("disabled", true);
        }
        else {
            $("#PaymodePopup").attr("disabled", false);
            $("#Paymodediv").show();
        }
        $("#hiddenSelectedInvoiceType").val(SelectedInvoiceType);
    }
    function DispalyPaymode() {
        var PaymentMethodDrop = $("#PaymentMethodDrop").val();
        if (PaymentMethodDrop == "Cash") {
            $("#passworddiv").hide();
            $("#DivHideShowID").show();
            $("#BillCalculation").attr("disabled", true);
            $('#IsV').prop('checked', false).trigger('change');

        }
        else {
            var checkIdNo = $("#IdNo").val();
            if (checkIdNo == "") {
                alert("Please enter IdNo");
                $("#IdNo").focus();
                $("#PaymentMethodDrop").val('Cash');

                return false;
            }
            $("#passworddiv").show();
            $("#DivHideShowID").hide();
            $("#BillCalculation").attr("disabled", false);
            $('#IsV').prop('checked', true).trigger('change');

        }
    }
    function ChangeGstType() {
        var GstType = $("#GstType").val();
        $("#HiddenGstType").val(GstType);
        if (GstType == "G") {
            $("#TaxTypediv").show();
        }
        else {
            $("#TaxTypediv").hide();
        }
    }
</script>

