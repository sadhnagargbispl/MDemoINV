@model InventoryManagement.Entity.Common.Draw
@using InventoryManagement.Common
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "LuckyDrawMaster";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    string CurrentPartyName = (Session["LoginUser"] as User).PartyName;
}

<script type="text/javascript">
    var grid, dialog;    
    var DrawArray = [];    
    $(document).ready(function () {
        $(".preloader").hide();
        
        getList();

        $("form[name=form_LuckyDraw]").unbind("submit");
        $("form[name=form_LuckyDraw]").bind('submit', function (e) {
            
            var formdata = new FormData($(this)[0]);
            console.log("form data = > " + formdata);
            $.ajax({
                url: '/Transaction/SaveDraw',
                type: 'POST',
                data: formdata,
                processData: false,
                contentType: false,
                dataType: "json",
                success: function (objResponse) {
                    $("#form_LuckyDraw").get(0).reset()
                    $(".preloader").hide();
                    if (objResponse != null) {
                        if (objResponse.ResponseStatus == "OK") {
                            OpenDialog("dialogMessage", "Saved Successfully", "false");
                            window.location.reload();
                        }
                        else {
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                        }
                    }
                },
                error: function (xhr, data) {
                    $(".preloader").hide();
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });

            return false;
        });

        $("#ProdCode").change(function () {
            $("#ProductName").val($("#ProdCode option:selected").text());
        });

       
        
        $("#FDate").datetimepicker({
            format: 'DD-MM-YYYY',
            minDate: new Date(),            
            widgetPositioning: {
                horizontal: 'auto',
                vertical: 'bottom'
            }
        }).on('dp.change', function (e) {
            var selectedDate = e.date._d;
            var lengthOfMonth = ((selectedDate.getMonth() + 1).toString()).length;
            var twoDigitMonth = (lengthOfMonth > 1) ? (selectedDate.getMonth() + 1) : '0' + (selectedDate.getMonth() + 1);
            var lengthOfDate = ((selectedDate.getDate()).toString()).length;
            var twoDigitdate = (lengthOfDate > 1) ? (selectedDate.getDate()) : '0' + (selectedDate.getDate());

            var newFromDate = twoDigitdate + "-" + twoDigitMonth + "-" + selectedDate.getFullYear();

            $("#FdateStr").val(newFromDate);

        });


        
    });            

    function getList() {
        $(".preloader").show();
        
       
            $.ajax({
                url: "getAllDraws",
                type: 'GET',               
                dataType: "json",
                success: function (objResult) {
                    $(".preloader").hide();
                    DrawArray = [];
                    if (objResult != null && objResult.length > 0) {
                        for (var i = 0; i < objResult.length; i++) {
                            var date = new Date(parseInt(objResult[i].FDate.substr(6)));
                            var formatted =  
                                  ("0" + date.getDate()).slice(-2) + "-" +
                                  ("0" + (date.getMonth() + 1)).slice(-2) + "-"  +date.getFullYear() ;
                            DrawArray.push({ "AID": objResult[i].AID, "Delete": "delete", "ProdCode": objResult[i].ProdCode, "ProductName": objResult[i].ProductName, "FDate": formatted, "BillSeq": objResult[i].BillSeq });
                        }
                    }
                    fillGrid();
                },
                error: function (xhr, data) {
                    $(".preloader").hide();
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });
    }

    function fillGrid() {

        $("#noRecord").hide();
        if (grid != null) {
            grid.destroy();
            $('#FreeProductgrid').empty();
        }

        grid = $('#FreeProductgrid').grid({
            dataSource: DrawArray,
            uiLibrary: 'bootstrap',
            headerFilter: false,
            columns: [
                { field: 'AID', title: 'AID', width: 120, sortable: true, hidden: true, filterable: true },
                { field: 'FDate', title: 'Date', width: 120, sortable: true, hidden: false, filterable: true },
                { field: 'BillSeq', title: 'BillSeq', width: 120, sortable: true, hidden: false, filterable: true },
                { field: 'ProdCode', title: 'Product Code', width: 100, sortable: true, hidden: false, filterable: false },
                { field: 'ProductName', title: 'Product Name', width: 100, sortable: true, hidden: false, filterable: true },
                 { title: '', field: 'Delete', width: 34, type: 'icon', width: 70, icon: 'glyphicon-remove', tooltip: 'Delete', events: { 'click': Delete }, filterable: false }
            ],
            pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
        });

    }
    
    function Delete(ev) {
        //var SingleProduct = $.grep(DrawArray, function (e) {
        //    return e.ProductCode == ev.data.record.OfferID;
        //});
        var link = '@Url.Action("DeleteDraw", "Transaction",new { id = "-1"})';        
        link = link.replace("-1", ev.data.record.AID);
        if (confirm('Are you sure?')) {
            console.log(ev);
            $.ajax({
                type: 'POST',
                url: link,
                success: function (resultData) {
                    if (resultData.ResponseStatus == "OK") {
                        window.location.reload();
                    }
                }
            });
            
        }
    }

    function OpenDialog(dialogId, Message, isConfirmation) {
        $("#" + dialogId).empty();
        $("#" + dialogId).append('<p>' + Message + '</p>');
        if (isConfirmation == "true") {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "Yes",
                    id: "btnYes" + dialogId,
                    click: function () {                     
                        IsYes = true;
                        $("#" + dialogId).dialog("close");


                    }
                },
                {
                    text: "No",
                    id: "btnNo" + dialogId,
                    click: function () {                      
                        IsYes = false;
                        $("#" + dialogId).dialog("close");
                    }
                }
                ]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }
        else {


            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btn" + dialogId,
                    click: function () {                        
                        $("#" + dialogId).dialog("close");


                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }

    }
</script>

<div class="row">


    <div class="clearfix"></div>

    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Offer > Lucky Draw Master</h2>

                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <form id="form_LuckyDraw" name="form_LuckyDraw" onsubmit="false">                       
                        <div class="col-lg-12 form-group">
                            
                                <label class="control-label col-lg-2"  for="category-name">
                                    Draw Date:
                                </label>
                                <div class="col-lg-4">
                                    @Html.HiddenFor(m => m.FdateStr, new { id = "FdateStr" })
                                    @Html.TextBoxFor(m => m.FDate, new { name = "FDate", id = "FDate", tabindex = "1", @required = "required", @class = "form-control col-md-4" })
                                </div>
                            </div>

                        

                        <div class="col-lg-12 form-group">
                            
                                <label class="control-label col-lg-2" for="category-name" >
                                    Product
                                </label>
                                <div class="col-lg-4">
                                    
                                    @Html.HiddenFor(m => m.ProductName, new { id = "ProductName" })
                                    @Html.DropDownListFor(m => m.ProdCode, new SelectList(ViewBag.ProductList, "ProdCode", "ProductName"), "--Select--", new { tabindex = "2", name = "ProdCode", id = "ProdCode", @class = "form-control col-lg-4", @required = "required" })
                                                                     
                                </div>
                           
                        </div>

                        <div class="col-lg-12 form-group">
                           
                                <label class="control-label col-lg-2" for="category-name">
                                    Bill Sequence
                                </label>
                                <div class="col-lg-4">
                                    @Html.TextBoxFor(m => m.BillSeq, new { tabindex = "3",type="number", @required = "required", name = "BillSeq", id = "BillSeq", @class = "form-control col-lg-4" })

                                </div>
                            
                        </div>
                                                                                                
                        <br />
                        <div class="col-lg-12" style="margin-top:1%">
                            <div class="col-lg-6 col-md-offset-3">                               
                                <input type="submit" id="SaveLuckyDrawForm" class="btn btn-success" tabindex="0" value="Save">
                                <button class="btn btn-primary" type="button" tabindex="0" id="cancelClick">Cancel</button>
                            </div>
                        </div>
                    </form>

                    <div class="col-lg-12">
                        <div class="form-group">
                            <br /><br />
                            <center>
                                <div class="loader" style="display:none"></div>
                            </center>

                            <center><span style="display:none" id="noRecord">No Records Found</span></center>
                            <br /><br /><br />
                            <table class="table bootstrap-datatable" id="FreeProductgrid"></table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <div id="dialogMessage" title="Message">

    </div>

</div>


