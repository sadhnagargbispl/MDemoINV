@model InventoryManagement.Entity.Common.Offer
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "Create Offer";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    string CurrentPartyName = (Session["LoginUser"] as User).PartyName;
    string PartyCaption = System.Configuration.ConfigurationManager.AppSettings["PartyCaption"];
}

<style>
    .ui-widget-header {
        margin-top: -1% !important;
        width: 102% !important;
        margin-left: -1% !important;
    }

    .gj-grid-wrapper {
        min-width: 100% !important;
        overflow-x: scroll !important;
    }

    .ui-dialog-titlebar-close {
        margin-right: 1% !important;
    }

    .ui-widget-content {
        background: white !important;
        border-radius: 15px !important;
        -webkit-border-radius: 4px !important;
    }

    ui-autocomplete-input {
        z-index: 100;
    }

    .input-readonly {
        background-color: #EBEBE4;
    }
</style>


<div class="row">

    <div class="clearfix"></div>

    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Offer > Sequence Product Offer</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <br />
                    <form id="CreateOtherOfferForm" method="post" name="CreateOtherOfferForm" onsubmit="return false" data-parsley-validate class="validateForm form-horizontal form-label-left">
                        @Html.HiddenFor(m => m.PrductString, new { name = "PrductString", id = "PrductString" })                        
                        @Html.HiddenFor(m => m.OfferID, new { name = "OfferID", id = "OfferID" })
                        @Html.HiddenFor(m => m.Action, new { name = "Action", id = "Action" })
                        @Html.HiddenFor(m => m.Party, new { name = "Party", id = "Party" })
                        @Html.HiddenFor(m => m.offerType, new { name = "offerType", id = "offerType" })
                        <div class="col-lg-12">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer Name:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.OfferName, new { name = "OfferName", id = "OfferName", tabindex = "1", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer Start Product:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.StartProduct, new { type = "number", name = "StartProduct", id = "StartProduct", tabindex = "5", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Start Date:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.OfferFromDt, new { name = "StartDate", id = "StartDate", tabindex = "2", @required = "required", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        End Date:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.OfferToDt, new { name = "EndDate", id = "EndDate", tabindex = "3", @required = "required", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-12">


                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer On BV:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.OfferOnBV, new { type = "number", name = "OfferOnBV", id = "OfferOnMinBV", tabindex = "4", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer To BV:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.TextBoxFor(m => m.OfferOnToBV, new { type = "number", name = "OfferOnToBV", id = "OfferOnToBV", tabindex = "4", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>


                        </div>

                        <div class="col-lg-12">

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Active Status:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.DropDownListFor(m => m.ActiveStatus, new SelectList(ViewBag.ActiveOptionDropDown, "Value", "Text"), "--Select--", new { name = "ActiveStatus", id = "ActiveStatus", tabindex = "6", @required = "required", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer Bill type :
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        @Html.DropDownListFor(m => m.ForBillType, new SelectList(ViewBag.ForBillTypeDropDown, "Value", "Text"), "--Select--", new { name = "ForBillType", id = "ForBillType", tabindex = "3", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col-lg-12">
                          
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-3 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Offer For @PartyCaption:
                                    </label>
                                    <div class="col-lg-9 col-md-6 col-sm-6 col-xs-12" style="padding-left: 0.5%;">
                                        <select multiple="multiple" id="OfferPartyList" name="OfferPartyList" class="form-control">
                                            @{

                                                foreach (var obj in Model.OfferParty)
                                                {
                                                    <option value="@obj.PartyCode">@obj.PartyName</option>
                                                }
                                            }
                                        </select>
                                        <input type="button" id="select_all" name="select_all" value="Select All">
                                    </div>
                                </div>
                            </div>
                          </div>

                


                    <div class="col-lg-12">

                       
                            <div class="col-lg-12">
                                <div class="col-lg-4 form-group">
                                    <input type="button" id="AddAllProduct" name="AddAllProduct" data-type="AddAllProduct" class="cancel btn btn-success" value="Add All Products" tabindex="11" />

                                </div>
                                <div class="col-lg-4 form-group">
                                    
                                </div>
                                <div class="col-lg-4">
                                    <input type="submit" tabindex="7" id="btnOtherOfferSave" name="btnOtherOfferSave" data-type="save" value="Save" class="btn btn-success" />
                                    <input type="button" tabindex="8" id="btnCancel" name="btnCancel" data-type="Cancel" class="cancel btn btn-success" value="Cancel" />
                                </div>

                            </div>

                        
                    </div>
                       

                        <div class="col-lg-12">
                            <div class="form-group">
                                <br /><br />
                                <center>
                                    <div class="loader" style="display:none"></div>
                                </center>

                                <center><span style="display:none" id="noRecord">No Records Found</span></center>
                                <br /><br /><br />
                                <table class="table bootstrap-datatable" id="FreeProductgrid"></table>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
    <div id="dialogMessage" title="Message">

    </div>

    <div id="AddProductdialog" title="Add Product" style="display:none">
        <div class="col-lg-12" style="background-color:lightgrey;border:1px black solid;">
            <span style="width:100%;"><center>Add Offer Product Details: </center></span>
        </div>
        <br />
        <div class="row" style="margin-top:1%">
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Product Code:
                </label>
                <div class="col-lg-6">
                    <input type="text" id="ProductCode" readonly="readonly" class="form-control" />
                </div>
            </div>

            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Product Name:
                </label>
                <div class="col-lg-6">
                    <input type="text" id="ProductName"  class="form-control" />
                </div>
            </div>

            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Quantity:
                </label>
                <div class="col-lg-6">
                    <input type="number" id="Quantity"  class="Quantity form-control" />
                </div>

            </div>
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Is Flexible:
                </label>
                <div class="col-lg-6">
                    <select name="IsFlexible" id="IsFlexible" class="IsFlexible form-control">
                        <option value="Y">Yes</option>
                        <option value="N">No</option>
                    </select>
                </div>

            </div>
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Free Quantity:
                </label>
                <div class="col-lg-6">
                    <input type="number" id="FreeQuantity" class="FreeQuantity form-control" />
                </div>

            </div>
        </div>
        <div class="row" style="margin-top:1%">
            <div class="col-lg-6 col-lg-offset-3">

                @*<button class="btn btn-primary" type="reset" onclick="reset()">Reset</button>*@
                <button type="button" id="YesBtn" class="btn btn-success" tabindex="0">Yes</button>
                <button class="btn btn-primary" type="button" id="NoBtn" tabindex="0">No</button>
            </div>
        </div>
    </div>

    <div id="AddAllProductdialog" title="Add Product Details" style="display:none">
        <div class="col-lg-12" style="background-color:lightgrey;border:1px black solid;">
            <span style="width:100%;"><center>Add Offer Product Details: </center></span>
        </div>
        <br />
        <div class="row" style="margin-top:1%">
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Quantity:
                </label>
                <div class="col-lg-6">
                    <input type="number" id="AllQuantity" class="Quantity form-control" />
                </div>

            </div>
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Is Flexible:
                </label>
                <div class="col-lg-6">
                    <select name="IsFlexible" id="AllIsFlexible" class="IsFlexible form-control">
                        <option value="Y">Yes</option>
                        <option value="N">No</option>
                    </select>
                </div>

            </div>
            <div class="col-lg-12 form-group">

                <label class="col-lg-6">
                    Free Quantity:
                </label>
                <div class="col-lg-6">
                    <input type="number" id="AllFreeQuantity" class="FreeQuantity form-control" />
                </div>

            </div>
        </div>
        <div class="row" style="margin-top:1%">
            <div class="col-lg-6 col-lg-offset-3">

                @*<button class="btn btn-primary" type="reset" onclick="reset()">Reset</button>*@
                <button type="button" id="AllYesBtn" class="btn btn-success" tabindex="0">Yes</button>
                <button class="btn btn-primary" type="button" id="AllNoBtn" tabindex="0">No</button>
            </div>
        </div>
    </div>

</div>


<script src="~/Scripts/CreateOffer.js?v=1"></script>

