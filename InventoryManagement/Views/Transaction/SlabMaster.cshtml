
@{
    ViewBag.Title = "Slab List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style type="text/css">
    .gj-grid-wrapper {
        min-width: 100% !important;
        overflow-x: scroll !important;
    }
</style>
<script type="text/javascript">
    var ErrorFlag = true;
    var SizeOfImage;
    var SlabGrid = [{}];
    var SlabModel = null;
    var grid, dialog;
    var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    $(document).ready(function () {
        $(".preloader").hide();
        fillGrid();
        $("#btnAdd").click(function () {
            ProductModel = null;
            var OfferType = $("#HiddenOfferType").val();
            var link = "";
            link = '@Url.Action("UpdateRpPoint", "Transaction",new { IsActionName = "Add", ID = "0"})';
            link = link.replace("-1", ProductModel);
            window.location.href = link;
        });

        function Edit(ev) {
            window.location.href = "/Transaction/UpdateRpPoint?IsActionName=Edit&ID=" + ev.data.record.ID;

        }
        function Delete(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.ProductCode == ev.data.record.OfferID;
            });
            var link = '@Url.Action("DeleteProductMaster", "Product",new { ProductCode = "-1"})';
            link = link.replace("-1", ev.data.record.OfferID);
            if (confirm('Are you sure?')) {
                console.log(ev);
                $.ajax({
                    type: 'POST',
                    url: link,
                    success: function (resultData) {
                        if (resultData.ResponseStatus == "OK") {
                            fillGrid();
                        }
                    }
                });

                //load the new data from the server after the deletion
            }
        }
        function fillGrid() {
            var link = '@Url.Action("GetAllSlabPoint", "Transaction")';
            SlabGrid = [{}];
            var OfferType = $("#HiddenOfferType").val();
            $.ajax({
                type: 'GET',
                url: link,
                success: function (resultData) {
                    $(".preloader").hide();
                    if (SlabGrid[0].ID == undefined)
                        SlabGrid = SlabGrid.splice(1);
                    $("#noRecord").hide();
                    if (grid != null) {
                        grid.destroy();
                        $('#grid').empty();
                    }

                    if (resultData != null) {
                        var i = 0;
                        SlabModel = resultData;
                        for (i = 0; i < resultData.length; i++) {
                            var dateObj = new Date(resultData[i].FromDate.match(/\d+/)[0] * 1);
                            var OfferFromDt = (dateObj.getDate()) + "-" + months[dateObj.getMonth()] + "-" + dateObj.getFullYear();
                            var TodateObj = new Date(resultData[i].ToDate.match(/\d+/)[0] * 1);
                            var OfferToDt = (TodateObj.getDate()) + "-" + months[TodateObj.getMonth()] + "-" + TodateObj.getFullYear();
                            //var mfgdateObj = new Date(resultData[i].OfferToDt.match(/\d+/)[0] * 1);
                            //var OfferToDt = (mfgdateObj.getDate()) + "-" + months[mfgdateObj.getMonth()] + "-" + mfgdateObj.getFullYear();
                            //var IdDate = "";
                            //if (resultData[i].IdDate != null && resultData[i].IdDate != "") {
                            //    var expdateObj = new Date(resultData[i].IdDate.match(/\d+/)[0] * 1);
                            //    IdDate = (expdateObj.getDate()) + "-" + months[expdateObj.getMonth()] + "-" + expdateObj.getFullYear();
                            //}
                            SlabGrid.push({
                                "ID": resultData[i].ID,
                                "SlabID": resultData[i].SlabID,
                                "SlabRange": resultData[i].SlabRange,
                                "FromDate": OfferFromDt,
                                "ToDate": OfferToDt,
                                "RPoint": resultData[i].RPoint
                            });
                        }

                        $("#noRecord").hide();
                        grid = $('#grid').grid({
                            dataSource: SlabGrid,
                            uiLibrary: 'bootstrap',
                            headerFilter: false,
                            columns: [
                                { field: 'ID', title: 'SNO.', sortable: false, hidden: false, width: 50, cssClass: "noExl", filterable: false },
                                { field: 'SlabRange', title: 'Slab Range', sortable: false, width: 70, cssClass: "noExl", filterable: false },
                                { field: 'FromDate', title: 'From Date', sortable: false, width: 100, hidden: false, cssClass: "noExl", filterable: false },
                                { field: 'ToDate', title: 'To Date', sortable: false, width: 70, hidden: false, cssClass: "noExl", filterable: false },
                                { field: 'RPoint', title: 'LB Point', sortable: false, width: 70, hidden: false, cssClass: "noExl", filterable: false },
                                { title: '', field: 'Edit', width: 34, type: 'icon', width: 70, icon: 'glyphicon-pencil', tooltip: 'Edit', events: { 'click': Edit }, filterable: false }
                            ],
                            pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
                        });

                    }
                    else {
                        $("#noRecord").show();
                    }

                }
            });
        }
    });
</script>
<div class="row">

    <div class="clearfix"></div>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    @if (ViewBag.OfferType == 1)
                    {
                        <h2>Offer > Buy 1 Get 1 Offer List</h2>
                    }
                    else if (ViewBag.OfferType == 2)
                    {
                        <h2>Offer > Rs. 1 product Offer List</h2>
                    }
                    else if (ViewBag.OfferType == 3)
                    {
                        <h2>Offer > Free product Offer List</h2>
                    }
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <br />
                    <div id="dialogMessage" title="Message">

                    </div>
                    <div class="col-lg-offset-10 col-lg-2">
                        <input type="hidden" value="@ViewBag.OfferType" id="HiddenOfferType">
                        <button id="btnAdd" type="button" class="btn btn-default" style="margin-top: 5%;margin-bottom: 5%">Add New Slab</button>
                    </div>
                    <div class="col-lg-12">
                        <table class="table bootstrap-datatable" id="grid"></table>
                        <center><span style="display:none" id="noRecord">No Records Found</span></center>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


