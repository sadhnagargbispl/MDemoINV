@model InventoryManagement.Entity.Common.WalletRequest
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "WalletRequest";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentPartyCode = string.Empty;
    if (Session["LoginUserType"] as string == "mobileshoppe")
    {
        CurrentPartyCode = (Session["LoginUser"] as User).UserName;
    }
    else
    {
        CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    }
    string CurrentPartyName = (Session["LoginUser"] as User).PartyName;
}


