@model IEnumerable <InventoryManagement.Entity.Common.KitDetail>
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentUsername = (Session["LoginUser"] as User).UserName;
    string CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    string CurrentPartyName = string.Empty;
    if (Session["LoginUserType"] as string == "mobileshoppe")
    {
        CurrentPartyName = (Session["LoginUser"] as User).Name;
    }
    else
    {
        CurrentPartyName = (Session["LoginUser"] as User).PartyName;
    }
}
<script type="text/javascript">
    $(document).ready(function () {
        $(".preloader").hide();
    });
</script>
<div class="row">
   
    <div class="clearfix"></div>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Dashboard</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>
                        
                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <h2><span>Welcome @CurrentUsername (@CurrentPartyName) !!</span></h2>
                    @*<div class="col-lg-12">
            <center><h2><span style="display:none">Your Wallet Balance is: &nbsp;<b>@ViewBag.WalletBalance</b></span></h2></center>
        </div>*@
                    <br />
@if (Model != null)
{
    foreach (var item in Model)
    {
                        <div class="col-lg-2 col-md-3 col-sm-6 col-xs-12">
                            <div class="x_panel" style="padding:8px 5px;">
                                <div class="x_title" style="height:40px">
                                    <b> @item.KitName </b>
                                    <div class="clearfix"></div>
                                </div>
                                <div class="x_content">
                                    <p>
                                        <div class="col-lg-12">
                                            <div class="col-lg-6">
                                                @item.KitId
                                            </div>
                                        </div>

                                    </p>
                                </div>
                            </div>
                        </div>
    }
}
                    </div>
                </div>
            </div>
        </div>
    </div>


