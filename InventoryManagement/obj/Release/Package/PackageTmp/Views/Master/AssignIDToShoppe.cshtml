@model InventoryManagement.Entity.Common.IdAssignment
@using InventoryManagement.Common
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "Assign Id Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    string CurrentPartyName = (Session["LoginUser"] as User).PartyName;
    string PartyCaption = System.Configuration.ConfigurationManager.AppSettings["PartyCaption"];
}
<style>
    .RowMargin {
        margin-bottom: 1%;
    }
    </style>
<script type="text/javascript">
    var dialog;
    var ListPCId = [];
    var AssignedId = [];
    var grid = null;
    var PartyList = [];
    var FullPartyList;

    $(document).ready(function () {
        $(".preloader").hide();
        GetAllParty();
        getAllPcId("All");
        $("#IdNo").focusout(function (e) {
            e.preventDefault();
            e.stopPropagation();
            var Value = $("#IdNo").val();
            if (Value != "")
                GetCustomerInfo(Value);
        });

        $("#cancelClick").click(function(){
            Reset();
        });

        $("#PartyName").autocomplete({
            source: function (request, response) {
                var results = $.ui.autocomplete.filter(PartyList, request.term);
                response(results.slice(0, 50));
            },
            minLength: 1,
            scroll: true,
            select: function (event, ui) {
                $("#PartyName").val(ui.item.label);
                SetSpecificCode("Party", ui.item.label);
                var partyCode = $("#PartyCode").val();
                
                return false;
            },
        }).focus(function () {
            $(this).autocomplete("search", "");
        });

        $("#SaveShoppeForm").click(function () {
            var idno = $("#IdNo").val();
            var pc = $("#PartyCode").val();
            if (pc == null || pc == "" || pc == undefined) {
                OpenDialog("dialogMessage", "Please select shoppe.", "false");
            }
            else {
                if (idno == null || idno == "" || idno == undefined) {
                    OpenDialog("dialogMessage", "Enter PC ID", "false");
                }
                else {
                    AssignIDToShoppe();
                }
            }
        });
    });


    function GetCustomerInfo(IdNo) {
        $(".preloader").show();
        $.ajax({
            url: '@Url.Action("GetCustInfo", "Transaction")',
            type: 'POST',
            data: { "IdNo": IdNo },
            dataType: "json",
            success: function (objResult) {
                $(".preloader").hide();
                if (objResult != null) {
                    if (objResult.Name == "") {
                        OpenDialog("dialogMessage", "Record does not exists.", "false");
                        $("#IdNo").val('');
                    }
                    else if (objResult.IsBlock) {
                        OpenDialog("dialogMessage", "Blocked ID not allowed.", "false");
                        $("#IdNo").val('');
                    }
                    else if (objResult.IsActive == false) {
                        OpenDialog("dialogMessage", "InActive ID not allowed.", "false");
                        $("#IdNo").val('');
                    }
                    else {                        
                        $("#IdNo").val(objResult.IdNo);
                        $("#Name").val(objResult.Name);
                        $("#Password").val(objResult.Password);
                    }
                }
                else {
                    Reset();
                    OpenDialog("dialogMessage", "Record Does Not Exists", "false");

                }
            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });

    }


    function OpenDialog(dialogId, Message, isConfirmation) {
        $("#" + dialogId).empty();
        if (Message != "" || Message != null) {

            $("#" + dialogId).append('<p>' + Message + '</p>');
        }
        if (isConfirmation == "true") {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "Yes",
                    id: "btnYes" + dialogId,
                    click: function () {
                        IsYes = true;
                        $("#" + dialogId).dialog("close");
                    }
                },
                {
                    text: "No",
                    id: "btnNo" + dialogId,
                    click: function () {
                       IsYes = false;
                        $("#" + dialogId).dialog("close");
                    }
                }
                ]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }
        else {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btn" + dialogId,
                    click: function () {
                       $("#" + dialogId).dialog("close");
                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }

    }

    function AssignIDToShoppe() {
        $(".preloader").show();
        var ListObjStr = AssignedId;
        $("#IdString").val(ListObjStr);
        var formdata = new FormData($("#form_shoppe")[0]);

        $.ajax({
            url: '@Url.Action("AssignIDToShoppe", "Master")',
            type: 'POST',
            data: formdata,
            processData: false,
                contentType: false,
                dataType: "json",
                success: function (objResponse) {
                    $(".preloader").hide();
                    if (objResponse != null) {
                        if (objResponse.ResponseStatus == "Ok") {
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                            Reset();
                            getAllPcId("All");
                        }
                        else {

                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                        }
                    }
                },
                error: function (xhr, data) {
                   console.log(xhr);
                    console.log("Error:", data);
                }
            });
    }
    function Reset()
    {
        $("#IdNo").val("");
        $("#Name").val("");
        $("#Password").val("");
    }
    function SetSpecificCode(type, label) {
        if (type == "Party") {
            for (var i = 0; i < FullPartyList.length; i++) {
                if (FullPartyList[i].PartyName == label) {
                    $("#PartyCode").val(FullPartyList[i].PartyCode);
                    break;
                }
            }
        }
    }

    function GetAllParty() {
        $.ajax({
            url: '/Report/GetAllPartyListForReports',
            dataType: 'JSON',
            method: 'GET',
            success: function (data) {
                FullPartyList = data;
                PartyList = [];
                if (data != null) {
                    var i = 0;
                    for (i = 0; i < data.length; i++) {
                        PartyList.push(data[i].PartyName);
                    }
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }

    function getAllPcId(PartyCode)
    {
        $.ajax({
            url: '/Master/GetAllPCID',
            dataType: 'JSON',
            method: 'GET',
            data :{"PartyCode" : "All"},
            success: function (data) {
                ListPCId = [];
                if (data != null) {
                    var i = 0;
                    for (i = 0; i < data.length; i++) {
                        ListPCId.push({ "SNo": (i + 1), "IdNo": data[i].IdNo, "PartyCode": data[i].PartyCode, "Party": data[i].PartyName, "FormNo": data[i].FormNo, "Name": data[i].Name, "Password": data[i].Password });
                    }
                    fillGrid();
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    }

    function fillGrid() {
        $("#noRecord").hide();
        if (grid != null) {
            grid.destroy();
            $('#grid').empty();
        }

        grid = $('#grid').grid({
            dataSource: ListPCId,
            uiLibrary: 'bootstrap',
            headerFilter: true,
            columns: [
                 { field: 'SNo', title: 'S.No.', width: 80, sortable: true, hidden: false, filterable: false },
                 { field: 'Party', title: 'Party Name', width: 200, sortable: true, hidden: false, filterable: true },
                 { field: 'PartyCode', title: 'Party Code', width: 200, sortable: true, hidden: false, filterable: true },                 
                 { field: 'IdNo', title: 'PCID', width: 200, sortable: true, hidden: false, filterable: true },
                 { field: 'Name', title: 'Name', width: 200, sortable: true, hidden: false, filterable: true },
                 { field: 'Password', title: 'Password', width: 200, sortable: true, hidden: false, filterable: true }
            ],
            pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
        });
    }





</script>

<div class="row">

    <div class="clearfix"></div>

    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Master > Shoppe Assignment</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>
                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <form id="form_shoppe" name="form_shoppe" onsubmit="return false;">
                        <div class="row RowMargin">
                            <div class="col-lg-8">
                                <label class="control-label col-lg-2" for="category-name">
                                    @PartyCaption: @*<span class="required">*</span>*@
                                </label>
                                <div class="col-lg-10" style="padding-left: 1%;">
                                    @Html.HiddenFor(m => m.PartyCode, new { id = "PartyCode", name = "PartyCode" })
                                    @Html.TextBoxFor(m => m.PartyName, new { name = "PartyName", id = "PartyName", tabindex = "0", @class = "form-control" })
                                </div>
                            </div>

                            <div class="col-lg-4">
                                &nbsp;
                            </div>
                        </div>

                        <div class="row RowMargin">
                            <div class="col-lg-8">
                                <label class="control-label col-lg-2" for="category-name">
                                   Pc Id: @*<span class="required">*</span>*@
                                </label>
                                <div class="col-lg-10" style="padding-left: 1%;">
                                    @Html.TextBoxFor(m => m.IdNo, new { name = "IdNo", id = "IdNo", tabindex = "1", @class = "form-control" })
                                </div>
                            </div>

                            <div class="col-lg-4">
                                &nbsp;
                            </div>
                        </div>
                        
                        <div class="row RowMargin">
                            <div class="col-lg-8">
                                <label class="control-label col-lg-2" for="category-name">
                                   PC Name: @*<span class="required">*</span>*@
                                </label>
                                <div class="col-lg-10" style="padding-left: 1%;">

                                    @Html.TextBoxFor(m => m.Name, new { name = "Name", id = "Name", tabindex = "3", @readonly = "readonly", @class = "form-control" })
                                </div>
                            </div>

                            <div class="col-lg-4">
                                &nbsp;
                            </div>
                        </div>
                        <div class="row RowMargin">
                            <div class="col-lg-8">
                                <label class="control-label col-lg-2" for="category-name">
                                    Password: @*<span class="required">*</span>*@
                                </label>
                                <div class="col-lg-10" style="padding-left: 1%;">
                                    @Html.TextBoxFor(m => m.Password, new { name = "Password", id = "Password", tabindex = "4", @readonly = "readonly", @class = "form-control" })
                                </div>
                            </div>

                            <div class="col-lg-4">
                                &nbsp;
                            </div>
                        </div>
                        <div class="row RowMargin">
                            <div class="col-lg-8">
                                <label class="control-label col-lg-2" for="category-name">
                                    &nbsp;
                                </label>
                                <div class="col-lg-10" style="padding-left: 1%;">
                                    <input type="button" id="SaveShoppeForm" class="btn btn-success" tabindex="0" value="Save">
                                    <button class="btn btn-primary" type="button" tabindex="0" id="cancelClick">Clear</button>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                &nbsp;
                            </div>                            
                        </div>
                        <div class="row RowMargin">
                            <table class="table bootstrap-datatable" id="grid"></table>
                            <center><span style="display:none" id="noRecord">No Record Found</span></center>
                        </div>


                    </form>
                </div>
            </div>
        </div>
    </div>
    <div id="dialogMessage" title="Message">

    </div>


</div>
