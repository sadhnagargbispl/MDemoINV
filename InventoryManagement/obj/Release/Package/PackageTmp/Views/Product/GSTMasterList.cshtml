
@{
    ViewBag.Title = "GSTMasterList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style type="text/css">
    .gj-grid-wrapper {
        min-width: 100% !important;
        overflow-x: scroll !important;
    }
</style>

<script type="text/javascript">
    var ErrorFlag = true;
    var SizeOfImage;
    var ProductGrid = [{}];
    var ProductModel = null;
    var grid, dialog;
    $(document).ready(function () {
        $(".preloader").hide();
        fillGrid();
        $("#btnAdd").click(function () {
            window.location.href = "/Product/ADDEditGST";
        });

        function Edit(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.ProductCode == ev.data.record.ProductCode;
            });
            console.log(" ev.data.record.ProductCode", ev.data.record.ProductCode);
            var prodcode = ev.data.record.ProductCode;
            var link = '@Url.Action("ProductMaster", "Product",new { ActionName = "Edit", ProductCode = "-1" })';
            link = link.replace("-1", ev.data.record.ProductCode);
            console.log("link",link);
            window.location.href = "/Product/ProductMaster?ActionName=Edit&ProductCode=" + ev.data.record.ProductCode;
        }

        function DeActive(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.BarcodeId == ev.data.record.BarcodeId;
            });
            var link = '@Url.Action("DeActiveBarcode", "Product",new { BCode = "-1"})';
            link = link.replace("-1", ev.data.record.BarcodeId);

                $.ajax({
                    type: 'POST',
                    url: link,
                    success: function (objResponse) {
                        if (objResponse.ResponseStatus == "OK") {
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                            fillGrid();
                        }
                    }
                });

        }
        function OpenDialog(dialogId, Message, isConfirmation) {
            if (isConfirmation == "true") {

            }
            else {
                $("#" + dialogId).empty();
                $("#" + dialogId).append('<p>' + Message + '</p>');

                $("#" + dialogId).dialog({
                    modal: true,
                    buttons: [{
                        text: "OK",
                        id: "btn" + dialogId,
                        click: function () {
                            $("#" + dialogId).dialog("close");
                        }
                    }]
                });
                $(".ui-dialog-titlebar-close").empty();
                $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
            }


        }
        function Edit(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.BarcodeId == ev.data.record.BarcodeId;
            });
            console.log(" ev.data.record.BarcodeId", ev.data.record.BarcodeId);
            var prodcode = ev.data.record.BarcodeId;
            var link = '@Url.Action("BarcodeMaster", "Product",new { ActionName = "Edit", BarcodeId = "-1" })';
            link = link.replace("-1", ev.data.record.BarcodeId);
            console.log("link", link);
            window.location.href = "/Product/BarcodeMaster?ActionName=Edit&BarcodeId=" + ev.data.record.BarcodeId;
        }


        function fillGrid(){
            var link = '@Url.Action("GetGSTList", "Product")';
            ProductGrid = [{}];

            $.ajax({
                type: 'POST',
                url: link,
                success: function (resultData) {
                    $(".preloader").hide();
                    if (ProductGrid[0].ProductCode == undefined)
                        ProductGrid = ProductGrid.splice(1);
                    $("#noRecord").hide();
                 
                    if (grid != null) {
                        grid.destroy();
                        $('#grid').empty();

                    }

                    if (resultData != null) {
                        var i = 0;
                        ProductModel = resultData;
                        for (i = 0; i < resultData.length; i++) {

                            debugger;

                            ProductGrid.push({
                                "SNo": (i + 1),
                                "GST": resultData[i].GSTTax
                            });
                        }

                        $("#noRecord").hide();
                        grid = $('#grid').grid({
                            dataSource: ProductGrid,
                            uiLibrary: 'bootstrap',
                            headerFilter: true,
                            columns: [
                                { field: 'SNo', title: 'SNo.', sortable: false, hidden: false,width: 50, cssClass: "noExl", filterable: false },
                                { field: 'GST', title: 'GST Per.', sortable: true, width: 70, filterable: true }
                            ],
                            pager: { limit: 100, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
                        });

                    }
                    else {
                        $("#noRecord").show();
                    }

                }
            });
        }
    });
</script>
<div class="row">

    <div class="clearfix"></div>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Product > GST List</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <br />
                    <div id="dialogMessage" title="Message">

                    </div>
                    <div class="col-lg-offset-10 col-lg-2">
                        <button id="btnAdd" type="button" class="btn btn-default" style="margin-top: 5%;margin-bottom: 5%">Add New GST</button>
                    </div>
                    <div class="col-lg-12">
                        <table class="table bootstrap-datatable" id="grid"></table>
                        <center><span style="display:none" id="noRecord">No Records Found</span></center>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

