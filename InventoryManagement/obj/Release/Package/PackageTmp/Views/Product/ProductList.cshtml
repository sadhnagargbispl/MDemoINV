
@{
    ViewBag.Title = "ProductList";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string CVCaption = System.Configuration.ConfigurationManager.AppSettings["CVCaption"];
    string BVCaption = System.Configuration.ConfigurationManager.AppSettings["BVCaption"];
    string PVCaption = System.Configuration.ConfigurationManager.AppSettings["PVCaption"];
    string RPCaption = System.Configuration.ConfigurationManager.AppSettings["RPCaption"];
    string BarcodeCaption = System.Configuration.ConfigurationManager.AppSettings["BarcodeCaption"];
}
<style type="text/css">
    .gj-grid-wrapper {
        min-width: 100% !important;
        overflow-x: scroll !important;
    }
</style>
<script type="text/javascript">
    var ErrorFlag = true;
    var SizeOfImage;
    var ProductGrid = [{}];
    var ProductModel = null;
    var grid, dialog;
    $(document).ready(function () {
        $(".preloader").hide();
        fillGrid();
        $("#btnAdd").click(function () {
            ProductModel = null;
            var link = '@Url.Action("ProductMaster", "Product",new { ActionName = "Add", ProductCode = "-1"})';
            link = link.replace("-1", ProductModel);
            window.location.href = link;
        });
        function Edit(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.ProductCode == ev.data.record.ProductCode;
            });
            console.log(" ev.data.record.ProductCode", ev.data.record.ProductCode);
            var prodcode = ev.data.record.ProductCode;
            var link = '@Url.Action("ProductMaster", "Product",new { ActionName = "Edit", ProductCode = "-1" })';
            link = link.replace("-1", ev.data.record.ProductCode);
            console.log("link", link);
            window.location.href = "/Product/ProductMaster?ActionName=Edit&ProductCode=" + ev.data.record.ProductCode;
        }
        function Delete(ev) {
            var SingleProduct = $.grep(ProductModel, function (e) {
                return e.ProductCode == ev.data.record.ProductCode;
            });
            var link = '@Url.Action("DeleteProductMaster", "Product",new { ProductCode = "-1"})';
            link = link.replace("-1", ev.data.record.ProductCode);
            if (confirm('Are you sure?')) {
                console.log(ev);
                $.ajax({
                    type: 'POST',
                    url: link,
                    success: function (resultData) {
                        if (resultData.ResponseStatus == "OK") {
                            fillGrid();
                        }
                    }
                });

                //load the new data from the server after the deletion
            }
        }
        function fillGrid() {
            var link = '@Url.Action("GetProductList", "Product")';
            ProductGrid = [{}];

            $.ajax({
                type: 'POST',
                url: link,
                success: function (resultData) {
                    $(".preloader").hide();
                    if (ProductGrid[0].ProductCode == undefined)
                        ProductGrid = ProductGrid.splice(1);
                    $("#noRecord").hide();
                    console.log("ProductGrid", ProductGrid);
                    if (grid != null) {
                        grid.destroy();
                        $('#grid').empty();

                    }

                    if (resultData != null) {
                        var i = 0;
                        ProductModel = resultData;
                        for (i = 0; i < resultData.length; i++) {
                            debugger;
                            var productPic = resultData[i].ProductImagePath;
                            var productPicFileName = productPic.replace(/^.*[\\\/]/, '');
                            //productPicFileName = productPic.replace(/\s/g, "%20");
                            productPicFileName = window.location.origin + "/ProductImages/" + productPic.replace(/\s/g, "%20");
                            console.log("ProductGridProductImages", productPicFileName);
                            var catname = resultData[i].ProductCategoryDetails.CategoryName;
                            var subcatname = resultData[i].ProductSubCategoryDetails.subCategoryName;
                            //var path = resultData[i].ProductCategoryDetails.CategoryName + " >> " + resultData[i].ProductSubCategoryDetails.subCategoryName + " >>" + resultData[i].ProductName;
                            var path = resultData[i].ProductName;
                            var dateObj = new Date(resultData[i].ProductBarcodeDetails.GenerateDate.match(/\d+/)[0] * 1);
                            var generatedDate = (dateObj.getDate()) + "/" + (dateObj.getMonth() + 1) + "/" + dateObj.getFullYear();
                            var mfgdateObj = new Date(resultData[i].ProductBarcodeDetails.MfgDate.match(/\d+/)[0] * 1);
                            var mfgDate = (mfgdateObj.getDate()) + "/" + (mfgdateObj.getMonth() + 1) + "/" + mfgdateObj.getFullYear();
                            var expdateObj = new Date(resultData[i].ProductBarcodeDetails.ExpDate.match(/\d+/)[0] * 1);
                            var expDate = (expdateObj.getDate()) + "/" + (expdateObj.getMonth() + 1) + "/" + expdateObj.getFullYear();
                            ProductGrid.push({
                                "SNo": (i + 1), "ProductId": resultData[i].ProductId, "ProductImage": productPicFileName, "GSTTax": resultData[i].ProductTaxDetails.GSTTax, "OpeningStockQty": resultData[i].ProductCurrentStockDetails.OpeningStockQty, "MinQty": resultData[i].MinQtyStr, "ProductCode": resultData[i].ProductCode, "ProductDescription": resultData[i].ProductDescription, "ProductCommission": resultData[i].ProductCommission, "CatName": catname, "SubCatName": subcatname, "CategoryId": resultData[i].CategoryId, "SubCategoryId": resultData[i].SubCatId, "CategoryName": resultData[i].ProductCategoryDetails.CategoryName, "SubCategoryName": resultData[i].ProductSubCategoryDetails.subCategoryName, "Product": path, "DiscountInRs": resultData[i].DiscountInRs, "DiscountPer": resultData[i].DiscountPer, "UserDefinedCode": resultData[i].UserDefinedCode, "Barcode": resultData[i].ProductBarcodeDetails.Barcode, "BarcodeType": resultData[i].ProductBarcodeDetails.BarcodeType, "ExpDate": expDate, "MfgDate": mfgDate, "MRP": resultData[i].ProductBarcodeDetails.MRP, "PurchaseRate": resultData[i].ProductBarcodeDetails.PurchaseRate, "GenerateDate": generatedDate, "DP": resultData[i].ProductBarcodeDetails.DP,
                                "Status": (resultData[i].IsActive) ? "Active" : "Inactive",
                                "IsBillingAllowed": (resultData[i].IsBillingAllowed) ? "Yes" : "No",
                                "IsAvailableforOffers": (resultData[i].IsAvailableforOffers) ? "Yes" : "No",
                                "AllowedForFPV": (resultData[i].AllowedForFPV) ? "Yes" : "No",
                                "AllowedForGV": (resultData[i].AllowedForGV) ? "Yes" : "No",
                                "AllowedForMRI": (resultData[i].AllowedForMRI) ? "Yes" : "No",
                                "AllowedForGPV": (resultData[i].AllowedForGPV) ? "Yes" : "No",
                                "HSNCode": resultData[i].HSNCode, "Weight": resultData[i].Weight,
                                "SJPDiscount": resultData[i].SJPDiscount
                            });
                        }

                        $("#noRecord").hide();
                        debugger;

                        grid = $('#grid').grid({

                            dataSource: ProductGrid,
                            uiLibrary: 'bootstrap',
                            headerFilter: true,
                            columns: [
                                { field: 'SNo', title: 'SNo.', sortable: false, hidden: false, width: 50, cssClass: "noExl", filterable: false },
                                { field: 'ProductId', title: 'ProductId', sortable: false, width: 70, hidden: true, cssClass: "noExl", filterable: false },
                                { field: 'ProductCode', title: 'Product Code', width: 70, sortable: true, hidden: false, cssClass: "noExl", filterable: true },
                                { field: 'CatName', title: 'Category', width: 100, sortable: true, hidden: false, cssClass: "noExl", filterable: true },
                                { field: 'SubCatName', title: 'Sub Category', width: 100, sortable: true, hidden: false, cssClass: "noExl", filterable: true },
                                { field: 'Product', title: 'Product', width: 100, sortable: true, hidden: false, cssClass: "noExl", filterable: true },
                                //{
                                //    title: 'Product Image',
                                //    width: 120,
                                //    tmpl: "<img src='{ProductImage}' width='100' height='100' alt='No Image' onerror=\"this.onerror=null;this.src='" + window.location.origin + "/images/ProductImages/DefaultProduct.jpg';\">",
                                //    align: 'center',
                                //    filterable: false
                                //},
                                //{ title: 'Product Image', width: 120, tmpl: "<img src={ProductImage} width='100' height='100' alt='No Image'>", align: 'center', filterable: false },
                                { field: 'MRP', title: 'MRP', width: 70, sortable: true, filterable: true },
                                //{ field: 'MfgDate', title: 'Mfg. Date', width: 70, sortable: true, filterable: true },
                                  //{ field: 'ExpDate', title: 'Exp. Date', width: 70, sortable: true, filterable: true },
                                  { field: 'ProductCommission', title: 'Prod. Commssn.', hidden: true, width: 70, sortable: true, filterable: true },
                                  //{ field: 'ProductDescription', title: 'Prod. Desc.', width: 100, sortable: true, filterable: true },
                                  //{ field: 'UserDefinedCode', title: 'User Defined Code', width: 70, sortable: true, filterable: true },
                                  //{ field: 'MinQty', title: 'Min. Qty.', sortable: true, width: 70, filterable: true },
                                 { field: 'Weight', title: 'Weight', width: 70, sortable: true, filterable: true },
                                   { field: 'DP', title: 'RCP', sortable: true, width: 70, filterable: true },
                                   { field: 'PurchaseRate', title: 'Purchase Rate', hidden: true, width: 70, sortable: true, filterable: true },
                                   { field: 'GSTTax', title: 'GST Tax', width: 70, sortable: true, filterable: true },
                                     { field: 'HSNCode', title: 'HSN Code', width: 70, sortable: true, filterable: true },
                                   { field: 'Barcode', title: '@BarcodeCaption', width: 70, sortable: true, filterable: true },
                                   { field: 'BarcodeType', title: '@BarcodeCaption Type', width: 70, sortable: true, filterable: true },
                                   //{ field: 'GenerateDate', title: 'Generate Date', width: 70, sortable: true, filterable: true },
                                { field: 'Status', title: 'Status', sortable: true, width: 70, filterable: true },
                                 //{ field: 'IsBillingAllowed', title: 'Billing Allowed', sortable: true, width: 70, filterable: true },
                                  //{ field: 'IsAvailableforOffers', title: 'Available for Offers', sortable: true, width: 70, filterable: true },
                                   //{ field: 'AllowedForFPV', title: 'Allowed For FPV', sortable: true, width: 70, filterable: true },
                                    //{ field: 'AllowedForGPV', title: 'Allowed For CPV', sortable: true, width: 70, filterable: true },

                                  //{ field: 'AllowedForGV', title: 'Allowed For GV', sortable: true, width: 70, filterable: true },
                                     //{ field: 'AllowedForGV', title: 'Allowed For MRI', sortable: true, width: 70, filterable: true },
                                     // { field: 'SJPDiscount', title: 'SJP Discount %', sortable: true, width: 70, filterable: true },
                    { title: '', field: 'Edit', width: 34, type: 'icon', width: 70, icon: 'glyphicon-pencil', tooltip: 'Edit', events: { 'click': Edit }, filterable: false },
                   { title: '', field: 'Delete', width: 34, type: 'icon', width: 70, icon: 'glyphicon-remove', tooltip: 'Delete', events: { 'click': Delete }, filterable: false }
                            ],
                            pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
                        });

                    }
                    else {
                        $("#noRecord").show();
                    }

                }
            });
        }
    });
</script>
<div class="row">
    <div class="clearfix"></div>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Product > Product List</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <br />
                    <div id="dialogMessage" title="Message">
                    </div>
                    <div class="col-lg-offset-10 col-lg-2">
                        <button id="btnAdd" type="button" class="btn btn-default" style="margin-top: 5%;margin-bottom: 5%">Add New Product</button>
                    </div>
                    <div class="col-lg-12">
                        <table class="table bootstrap-datatable" id="grid"></table>
                        <center><span style="display:none" id="noRecord">No Records Found</span></center>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

