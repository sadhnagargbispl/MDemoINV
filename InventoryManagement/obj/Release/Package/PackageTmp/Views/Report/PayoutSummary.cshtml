@model InventoryManagement.Entity.Common.M_PayoutSummary
@{
    ViewBag.Title = "PayoutSummary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .modal {
    text-align: center;
}

.modal:before {
    content: '';
    display: inline-block;
    height: 100%;
    vertical-align: middle;
}

.modal-dialog {
    display: inline-block;
    text-align: left;
    vertical-align: middle;
}
.modal-dialog {
    width: 80%;   /* or 90% */
    margin: 30px auto;
}
</style>

<script type="text/javascript">
     var grid, dialog;
    var BillWiseGrid = [{}];
    var PartyList = [];
    var FullPartyList;
    var IsParty = false;
    var IsMonth = false;
    var TransNoToUpdate = [];
    var FromDate = "", ToDate = "";
    $(document).ready(function () {
        GetAllParty();
        $(".preloader").hide();

        var partyselect = $("#PartyName").autocomplete({
            source: function (request, response) {
                var results = $.ui.autocomplete.filter(PartyList, request.term);

                response(results.slice(0, 50));
            },
            minLength: 1,
            scroll: true,
            select: function (event, ui) {
                $("#PartyName").val(ui.item.label);
                SetSpecificCode("Party", ui.item.label);
                return false;
            },

        }).focus(function () {
            $(this).autocomplete("search", "");
        });

        $('#IsParty').on('ifChecked', function () {
            IsParty = true;
            $("#PartyName").val('All');
            $("#PartyName").prop("readonly", "readonly");
            $("#PartyCode").val('All');
        });

        $('#IsParty').on('ifUnchecked', function () {
            IsParty = false;
            $("#PartyName").val('');
            $("#PartyName").prop("readonly", "");
            $("#PartyCode").val('');
        });

        $("#btnExport").on('click', function () {
            var UserTypeStr = "FranchiseeBVCommission";
            var tableString = "<thead><tr>";
            tableString += "<th>S.No.</th>";
            tableString += "<th>Franchisee Code</th>";
            tableString += "<th>Franchisee Name</th>";
            tableString += "<th>Franchisee Group</th>";
            tableString += "<th>BillNo </th>";
            tableString += "<th>BillDate</th>";
            tableString += "<th>BillType</th>";
            tableString += "<th>BV Value</th>";
            tableString += "<th>Commission Slab(%)</th>";
            tableString += "<th>Commission Value</th>";
             tableString += "<th>PV Value</th>";
            tableString += "<th>PV Slab</th>";
            tableString += "<th>PVCommission Value</th>";

            tableString += "</tr></thead><tbody>";
            for (var i = 0; i < BillWiseGrid.length; i++) {
                tableString += "<tr>";
                tableString += "<td>" + BillWiseGrid[i].SNo + "</td>";
                tableString += "<td>" + BillWiseGrid[i].PartyCode + "</td>";
                tableString += "<td>" + BillWiseGrid[i].PartyName + "</td>";
                tableString += "<td>" + BillWiseGrid[i].GroupName + "</td>";
                tableString += "<td>" + BillWiseGrid[i].BillNo + "</td>";
                tableString += "<td>" + BillWiseGrid[i].BillDate + "</td>";
                tableString += "<td>" + BillWiseGrid[i].BillType + "</td>";
                tableString += "<td>" + BillWiseGrid[i].BVCommission + "</td>";
                tableString += "<td>" + BillWiseGrid[i].CommissionSlab + "</td>";
                tableString += "<td>" + BillWiseGrid[i].Commission + "</td>";
                  tableString += "<td>" + BillWiseGrid[i].PVCommission + "</td>";
                  tableString += "<td>" + BillWiseGrid[i].PVSlab + "</td>";
                  tableString += "<td>" + BillWiseGrid[i].PVCommissionVal + "</td>";
                tableString += "</tr>";
            }

            tableString += "</tbody>";
            $("#gridExport").empty();
            $("#gridExport").append(tableString);
            tableToExcel('gridExport', UserTypeStr + "_Export");
        });

        $("#btnShowReport").on('click', function () {
            $(".preloader").show();
            var Sessid=$("#Sessid").val();
            if (Sessid == "0") {
                OpenDialog("dialogMessage", "Please select session", "false");
                $(".preloader").hide();
                return false;
            }
            var PartyCode = $("#PartyCode").val();
            if (PartyCode == "")
            {
                OpenDialog("dialogMessage", "Please enter party name", "false");
                $(".preloader").hide();
                return false;
            }
            $.ajax({
                    url: '/Report/GetMonthWiseIncome',
                    dataType: 'JSON',
                    method: 'POST',
                    data: { "Sessid": Sessid, "PartyCode": PartyCode },
                    success: function (data) {

                        //response(data);
                        if (data != null) {
                            BillWiseGrid = [{}];
                            console.log("data", data);
                            if (data.length > 0) {
                                BillWiseGrid = BillWiseGrid.splice(1);
                                for (var i = 0; i < data.length; i++) {
                                    var StatementPath = '@Url.Action("PayoutStatement", "Report", new { Prm = "-1" })';
                                    var encodedparameters = data[i].PartyCode+";"+Sessid;
                                    var EncryptedB64Url = window.btoa(encodedparameters);
                                    StatementPath = StatementPath.replace("-1", EncryptedB64Url);
                                    BillWiseGrid.push({
                                        "SNo": i + 1,
                                        "sessID": data[i].SessID,
                                        "Statement": StatementPath,
                                        "Code": data[i].PartyCode,
                                        "self_Comm_BV": parseFloat(data[i].Self_Comm_BV).toFixed(2),
                                        "diff_Comm_BV": parseFloat(data[i].Diff_Comm_BV).toFixed(2),
                                        "bV_Slab": data[i].BV_Slab,
                                        "selfIncomePv": data[i].SelfIncomePv,
                                        "diff_Comm_Pv": data[i].Diff_Comm_Pv,
                                        "pvSlab": data[i].PvSlab,
                                        "gross_Amount": data[i].Gross_Amount,
                                        "tds_Deduction": data[i].Tds_Deduction,
                                        "rndOff": data[i].RndOff,
                                        "netIncome": data[i].NetIncome,
                                        "AdminCharge": data[i].AdminCharge
                                    });
                                }

                                $("#noRecord").hide();
                                console.log("data:", data);
                                if (grid != null) {
                                    grid.destroy();
                                    $('#grid').empty();

                                }
                                grid = $('#grid').grid({
                                    dataSource: BillWiseGrid,
                                    uiLibrary: 'bootstrap',
                                    headerFilter: true,
                                    columns: [
                                         { field: 'SNo', title: 'SNo', width: 100, sortable: true, hidden: false, filterable: true, align: 'center' },
                                         { field: 'Statement', title: 'Statement', width: 130, sortable: true, hidden: false, filterable: true, tmpl: '<a target="_blank" style="text-decoration:underline;color:blue" href={Statement}>Open</a>', align: 'center' },
                                         { field: 'Code', title: 'Franchisee Code', width: 80, sortable: true, hidden: false, filterable: true },
                                         { field: 'self_Comm_BV', title: 'Self Comm - BV', width: 80, sortable: true, hidden: false, filterable: true },
                                         { field: 'diff_Comm_BV', title: 'Diff. Comm-BV', width: 80, sortable: true, hidden: false, filterable: true,
                                         tmpl: '<a style="text-decoration:underline;color:blue">{diff_Comm_BV}</a>', events: { 'click': openModal }},
                                         { field: 'bV_Slab', title: 'BV Slab', width: 80, sortable: true, hidden: false, filterable: true },
                                         { field: 'selfIncomePv', title: 'SelfIncome Pv', width: 80, sortable: true, hidden: false, filterable: true },
                                         { field: 'diff_Comm_Pv', title: 'Diff. Comm-Pv', width: 100, sortable: true, hidden: false, filterable: true,
                                         tmpl: '<a style="text-decoration:underline;color:blue">{diff_Comm_Pv}</a>', events: { 'click': openPvModal }
                                         },
                                         { field: 'pvSlab', title: 'PvSlab', width: 100, sortable: true, hidden: false, filterable: true },
                                         { field: 'gross_Amount', title: 'Gross Amount', width: 100, sortable: true, hidden: false, filterable: true },
                                         { field: 'tds_Deduction', title: 'Tds Deduction', width: 100, sortable: true, hidden: true, filterable: true },
                                         { field: 'AdminCharge', title: 'Admin Charge', width: 100, sortable: true, hidden: false, filterable: true },
                                         { field: 'rndOff', title: 'RndOff', width: 100, sortable: true, hidden: false, filterable: true },
                                         { field: 'netIncome', title: 'NetIncome', width: 100, sortable: true, hidden: false, filterable: true },
                                    ],
                                    pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
                                });

                                $(".preloader").hide();
                                // $("#btnExport").show();
                            }
                            else {
                                $(".preloader").hide();
                                $("#noRecord").show();
                                $('#grid').empty();
                                // $("#btnExport").hide();

                        //          toastr.error("No record found", 'Error', {
                        //closeButton: true,
                        //progressBar: true,
                        //positionClass: 'toast-top-right',
                        //timeOut: 8000, // 8 seconds
                        //extendedTimeOut: 2000 // 2 second longer than timeOut
                     //});
                            }
                        }
                    },
                    error: function (error) {
                        console.log(error);
                    }
                });
        });
    });

    function toDate(dateStr) {
        var parts = dateStr.split("-");
        return new Date(parts[2], parts[1] - 1, parts[0]);
    }

    function openModal(sno) {
        debugger;
       var SessID = $("#Sessid").val();
        //var row = BillWiseGrid.find(x => x.SNo == sno);
        var PartyCode = sno.data.record.Code;
            $.ajax({
                    url: '/Report/GetPerformanceInc',
                    dataType: 'JSON',
                    method: 'POST',
                    data: { "Action": "BV", "PartyCode": PartyCode, SessID: SessID },
                    success: function (data) {
                         // Find selected row data
        //var row = BillWiseGrid.find(x => x.SNo == sno);

        // 🔥 Build table HTML
            var html = `
                <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Party Code</th>
                            <th>MLevel</th>
                            <th>Diff. Comm-BV</th>
                             <th>Self Slab</th>
                             <th>Down Slab</th>
                            <th>Diff. Comm-Pv</th>
                            <th>Comm.</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            // Loop through data
            $.each(data, function (i, item) {
                html += `
                    <tr>
                        <td>${item.FromPartyCode}</td>
                        <td>${item.MLevel}</td>
                        <td>${item.Diff_Comm_BV}</td>
                         <td>${item.SelfSlab}</td>
                         <td>${item.DownSlab}</td>
                        <td>${item.Diff_Comm_Pv}</td>
                        <td>${item.Comm}</td>
                    </tr>
                `;
            });

            html += `</tbody></table></div>`;

            // Set modal content
            $('#modalContent').html(html);

        // Open modal
                        //$('#myModal').modal('show');
            OpenBVDetails();
                    },
                    error: function (error) {
                        console.log(error);
                    }
                });

    }

    function OpenBVDetails() {
        $("#myModal").dialog({
            width: 700,
            modal: true,
            buttons: [{
                text: "OK",
                id: "btndialogOrder",
                click: function () {
                    //var isOpen = $("#dialog").dialog("isOpen");
                    //if (isOpen == true) {
                    //    okCallBack();
                    //}

                    $("#myModal").dialog("close");


                }
            }]
        });
        $(".ui-dialog-titlebar-close").empty();
        $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
    }

        function openPvModal(sno) {
            var PartyCode = sno.data.record.Code;
            var SessID = $("#Sessid").val();
               $.ajax({
                    url: '/Report/GetPerformanceInc',
                    dataType: 'JSON',
                    method: 'POST',
                    data: { "Action": "PV", "PartyCode": PartyCode, SessID: SessID },
                    success: function (data) {
                        //var row = BillWiseGrid.find(x => x.SNo == sno);

       var html = `

                <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Party Code</th>
                            <th>MLevel</th>
                            <th>PV</th>
                            <th>Self Slab</th>
                            <th>Down Slab</th>
                            <th>Diff. Slab</th>
                            <th>Comm.</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            //  Loop data
            $.each(data, function (i, item) {

                html += `
                    <tr>
                        <td>${item.FromPartyCode}</td>
                        <td>${item.MLevel}</td>
                        <td>${item.Pv}</td>
                        <td>${item.SelfSlab}</td>
                        <td>${item.DownSlab}</td>
                        <td>${item.Slab}</td>
                        <td>${item.Comm}</td>
                    </tr>
                `;
            });

            html += `</tbody></table></div>`;

            // Set modal content
            $('#pvModalContent').html(html);

            OpenPVDetails();

                    },
                    error: function (error) {
                        console.log(error);
                    }
                });


        }

        function OpenPVDetails() {
            $("#pvModal").dialog({
                width: 700,
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btndialogOrder",
                    click: function () {
                        //var isOpen = $("#dialog").dialog("isOpen");
                        //if (isOpen == true) {
                        //    okCallBack();
                        //}

                        $("#pvModal").dialog("close");


                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }

        function OpenDialog(dialogId, Message, isConfirmation) {
            $("#" + dialogId).empty();
            $("#" + dialogId).append('<p>' + Message + '</p>');
            if (isConfirmation == "true") {
                $("#" + dialogId).dialog({
                    modal: true,
                    buttons: [{
                        text: "Yes",
                        id: "btnYes" + dialogId,
                        click: function () {
                            IsYes = true;
                            $("#" + dialogId).dialog("close");


                        }
                    },
                    {
                        text: "No",
                        id: "btnNo" + dialogId,
                        click: function () {
                            IsYes = false;
                            $("#" + dialogId).dialog("close");
                        }
                    }
                    ]
                });
                $(".ui-dialog-titlebar-close").empty();
                $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
            }
            else {


                $("#" + dialogId).dialog({
                    modal: true,
                    buttons: [{
                        text: "OK",
                        id: "btn" + dialogId,
                        click: function () {
                            $("#" + dialogId).dialog("close");
                        }
                    }]
                });
                $(".ui-dialog-titlebar-close").empty();
                $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');

            }

        }
        function GetAllParty() {
            $.ajax({
                url: '/Report/GetAllPartyListForReports',
                dataType: 'JSON',
                method: 'GET',
                async: false,
                success: function (data) {
                    console.log("data:", data);
                    //response(data);
                    FullPartyList = data;
                    PartyList = [];
                    if (data != null) {
                        var i = 0;
                        for (i = 0; i < data.length; i++) {
                            //console.log("data[i]", data[i]);
                            PartyList.push(data[i].PartyName);
                        }
                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        }

       

        function SetSpecificCode(type, label) {

            if (type == "Party") {
                for (var i = 0; i < FullPartyList.length; i++) {
                    if (FullPartyList[i].PartyName == label) {
                        $("#PartyCode").val(FullPartyList[i].PartyCode);
                        break;
                    }
                }
            }
        }

       
</script>


