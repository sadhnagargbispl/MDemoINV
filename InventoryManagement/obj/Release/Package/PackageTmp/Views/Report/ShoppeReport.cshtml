    function GetDetails(PartyCode) {
        $.ajax({
            url: '@Url.Action("GetShoppeReport", "Report")',
            type: 'POST',
            data: { "PartyCode": PartyCode },
            dataType: "json",
            success: function (objResult) {
                DataGrid = [];
                objColumns = objResult.columns;
                if (objResult.DashboardData.length > 0) {

                    for (var i = 0; i < objResult.DashboardData.length; i++) {
                        DataGrid.push({
                            "SNo": i + 1,
                            "PartyCode": objResult.DashboardData[i].PartyCode,
                            "PartyName": objResult.DashboardData[i].PartyName,
                            "UserName": objResult.DashboardData[i].UserName,
                            "TotalSale": objResult.DashboardData[i].TotalSale,
                            "TotalFV": objResult.DashboardData[i].TotalFV,
                            "TotalRV": objResult.DashboardData[i].TotalRV,
                            "TotalFVAmt": objResult.DashboardData[i].TotalFVAmt,
                            "TotalRVAmt": objResult.DashboardData[i].TotalRVAmt,
                            "LastMnthSale": objResult.DashboardData[i].LastMnthSale,
                            "LastMnthFV": objResult.DashboardData[i].LastMnthFV,
                            "LastMnthRV": objResult.DashboardData[i].LastMnthRV,
                            "LastMnthFVAmt": objResult.DashboardData[i].LastMnthFVAmt,
                            "LastMnthRVAmt": objResult.DashboardData[i].LastMnthRVAmt,
                            "LastMnthTDAmt": objResult.DashboardData[i].LastMnthTDAmt,
                            "LastMnthTDFV": objResult.DashboardData[i].LastMnthTDFV,
                            "LastMnthTDRV": objResult.DashboardData[i].LastMnthTDRV,
                            "LastMnthTDFVAmt": objResult.DashboardData[i].LastMnthTDFVAmt,
                            "LastMnthTDRVAmt": objResult.DashboardData[i].LastMnthTDRVAmt,
                            "MnthSale": objResult.DashboardData[i].MnthSale,
                            "MnthFV": objResult.DashboardData[i].MnthFV,
                            "MnthRV": objResult.DashboardData[i].MnthRV,
                            "MnthFVAmt": objResult.DashboardData[i].MnthFVAmt,
                            "MnthRVAmt": objResult.DashboardData[i].MnthRVAmt,
                            "TodaySale": objResult.DashboardData[i].TodaySale,
                            "TodayFV": objResult.DashboardData[i].TodayFV,
                            "TodayRV": objResult.DashboardData[i].TodayRV,
                            "TodayFVAmt": objResult.DashboardData[i].TodayFVAmt,
                            "TodayRVAmt": objResult.DashboardData[i].TodayRVAmt,
                            "TodayBillCnt": objResult.DashboardData[i].TodayBillCnt,
                            "TodayFVBillCnt": objResult.DashboardData[i].TodayFVBillCnt,
                            "TodayRVBillCnt": objResult.DashboardData[i].TodayRVBillCnt,
                            "StockVal": objResult.DashboardData[i].StockVal,
                            "StockQty": objResult.DashboardData[i].StockQty,
                            "WRVal": objResult.DashboardData[i].WRVal,
                            "WRQty": objResult.DashboardData[i].WRQty,
                            "FRVal": objResult.DashboardData[i].FRVal,
                            "FRQty": objResult.DashboardData[i].FRQty,
                            "LastMnthFVBillCnt": objResult.DashboardData[i].LastMnthFVBillCnt,
                            "LastMnthRVBillCnt": objResult.DashboardData[i].LastMnthRVBillCnt,
                            "LastMnthTDFVCnt": objResult.DashboardData[i].LastMnthTDFVCnt,
                            "LastMnthTDRVCnt": objResult.DashboardData[i].LastMnthTDRVCnt,
                            "MnthFVCnt": objResult.DashboardData[i].MnthFVCnt,
                            "MnthRVCnt": objResult.DashboardData[i].MnthRVCnt,
                            "TotalFVCnt": objResult.DashboardData[i].TotalFVCnt,
                            "TotalRVCnt": objResult.DashboardData[i].TotalRVCnt,
                            "WalletBalance": objResult.DashboardData[i].WalletBalance
                        });
                    }
                    $("#noRecord").hide();
                }
                else {

                    $("#noRecord").show();
                }
                fillGrid();
                $(".preloader").hide();

            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });



    }
</script>

