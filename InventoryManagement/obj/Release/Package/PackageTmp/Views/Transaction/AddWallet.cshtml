@model InventoryManagement.Entity.Common.Wallet
@using InventoryManagement.Common
@using InventoryManagement.Entity.Common
@{
    ViewBag.Title = "AddWallet";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string CurrentPartyCode = (Session["LoginUser"] as User).PartyCode;
    string CurrentPartyName = (Session["LoginUser"] as User).PartyName;
}

<script type="text/javascript">

    $(document).ready(function () {
        $(".preloader").hide();

        $("form[name=form_walletBalance]").unbind("submit");
        $("form[name=form_walletBalance]").bind('submit', function (e) {
            $("#SaveWalletBalance").attr("disabled", true);


            var formdata = new FormData($("#form_walletBalance")[0]);
            console.log("form data = > " + formdata);
            $.ajax({
                url: '@Url.Action("DebitCreditWallet", "Transaction")',
                type: 'POST',
                data: formdata,
                processData: false,
                contentType: false,
                dataType: "json",
                success: function (objResponse) {
                    $("#SaveWalletBalance").removeAttr("disabled");
                    if (objResponse != null) {
                        if (objResponse.ResponseStatus == "OK") {

                            var link = '@Url.Action("AddWallet", "Transaction")';
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                            window.location.href = link;

                        }
                        else {
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                        }
                    }
                    return false;
                },
                error: function (xhr, data) {
                    //  return false;
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });
            return false;
        });

        $('#FCode').change(function () {
            var selectedText = $("#FCode option:selected").text();

            // Copy to clipboard
            navigator.clipboard.writeText(selectedText)
                .then(function () {
                    //alert("Copied to clipboard: " + selectedText);
                })
                .catch(function (err) {
                    //alert("Failed to copy: ", err);
                });
        });

    });
    function OpenDialog(dialogId, Message, isConfirmation) {
        $("#" + dialogId).empty();
        $("#" + dialogId).append('<p>' + Message + '</p>');
        if (isConfirmation == "true") {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "Yes",
                    id: "btnYes" + dialogId,
                    click: function () {
                        IsYes = true;
                        $("#" + dialogId).dialog("close");


                    }
                },
                {
                    text: "No",
                    id: "btnNo" + dialogId,
                    click: function () {
                        IsYes = false;
                        $("#" + dialogId).dialog("close");
                    }
                }
                ]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }
        else {
            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btn" + dialogId,
                    click: function () {
                        $("#" + dialogId).dialog("close");
                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }
    }
</script>

<div class="row">
    <div class="page-title">
        <div class="title_left">
            <h3>User</h3>
        </div>
        <div class="title_right">
            <div class="col-md-5 col-sm-5 col-xs-12 form-group pull-right top_search">

            </div>
        </div>
    </div>

    <div class="clearfix"></div>

    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Add Wallet Balance</h2>

                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>

                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <form id="form_walletBalance" name="form_walletBalance" onsubmit="false">

                        <div class="col-lg-12">
                            <div class="row" style="margin-top:1%">
                                <label class="col-lg-3">Franchise<span style="color:red">*</span></label>
                                <div class="col-lg-6">
                                    @Html.DropDownListFor(m => m.FCode, ViewBag.PartyList as IEnumerable<SelectListItem>, new { id = "FCode", tabindex = "0", @required = "required", name = "FCode", @class = "form-control" })
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <div class="row" style="margin-top:1%">
                                <label class="col-lg-3">Wallet<span style="color:red">*</span></label>
                                <div class="col-lg-6">
                                    @Html.DropDownListFor(m => m.ACType, ViewBag.ACType as IEnumerable<SelectListItem>, new { id = "FCode", tabindex = "0", @required = "required", name = "FCode", @class = "form-control" })
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <div class="row" style="margin-top:1%">
                                <label class="col-lg-3">Amount<span style="color:red">*</span></label>
                                <div class="col-lg-6">
                                    @Html.TextBoxFor(m => m.Amount, new { id = "Amount", type = "number", tabindex = "1", @required = "required", name = "Amount", @step = ".01", @class = "form-control" })
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="row" style="margin-top:1%">
                                <label class="col-lg-3">Debit/Credit<span style="color:red">*</span></label>
                                <div class="col-lg-6">
                                    <label>@Html.RadioButtonFor(m => m.DrCr, "Debit", new { tabindex = "2", @required = "required" }) Debit</label> &nbsp; &nbsp; &nbsp; &nbsp;
                                    <label>@Html.RadioButtonFor(m => m.DrCr, "Credit")  Credit</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="row" style="margin-top:1%">
                                <label class="col-lg-3">Narration<span style="color:red">*</span></label>
                                <div class="col-lg-6">
                                    @Html.TextBoxFor(m => m.Narration, new { id = "Narration", tabindex = "3", name = "Narration", maxlength = "255", @class = "form-control", @required = "required" })
                                </div>
                            </div>
                        </div>



                        <br />

                        <div class="col-lg-12" style="margin-top:1%">
                            <div class="col-lg-6 col-md-offset-3">
                                <input type="submit" id="SaveWalletBalance" class="btn btn-success" tabindex="4" value="Save">
                                <button class="btn btn-primary" type="button" tabindex="5" id="cancelClick">Cancel</button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
    <div id="dialogMessage" title="Message">

    </div>

</div>

