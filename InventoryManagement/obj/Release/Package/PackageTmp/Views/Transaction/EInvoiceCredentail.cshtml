@model InventoryManagement.Entity.Common.M_EInvoiceCredential
@{
    ViewBag.Title = "EInvoiceCredentail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script type="text/javascript">
    var ECredentia = [{}];
    var dialog, gridUpper;
    $(document).ready(function () {
        GetEInvoiceCredentail();
        $(".preloader").hide();
        $("form[name=ECredentialForm]").bind('submit', function (e) {
            e.preventDefault();
            var r = confirm("Are you sure");
            if (r == true) {
                $("#SaveProductMasterBtn").attr("disabled", true);
                var Aspid = $("#Aspid").val();
                if (Aspid == "") {
                    alert("Please enter ASPID");
                    $("#Aspid").focus();
                    $("#SaveProductMasterBtn").attr("disabled", false);
                    return false;
                }
                var ApiPassword = $("#ApiPassword").val();
                if (ApiPassword == "") {
                    alert("Please enter ApiPassword");
                    $("#ApiPassword").focus();
                    $("#SaveProductMasterBtn").attr("disabled", false);
                    return false;
                }
                var Gstin = $("#Gstin").val();
                if (Gstin == "") {
                    alert("Please enter GSTIN");
                    $("#Gstin").focus();
                    $("#SaveProductMasterBtn").attr("disabled", false);
                    return false;
                }
                var Username = $("#Username").val();
                if (Username == "") {
                    alert("Please enter Username");
                    $("#Username").focus();
                    $("#SaveProductMasterBtn").attr("disabled", false);
                    return false;
                }
                var EInvPwd = $("#EInvPwd").val();
                if (EInvPwd == "") {
                    alert("Please enter EInvPwd");
                    $("#EInvPwd").focus();
                    $("#SaveProductMasterBtn").attr("disabled", false);
                    return false;
                }
                e.stopPropagation();
                var link = '@Url.Action("SaveEInvoiceCredentail", "Transaction")';
                var formdata = new FormData($(this)[0]);
                console.log("form data = > " + formdata);
                $.ajax({
                    url: link,
                    type: 'POST',
                    data: formdata,
                    processData: false,
                    contentType: false,
                    dataType: "json",
                    success: function (objResponse) {
                        debugger;
                        $("#SaveProductMasterBtn").removeAttr("disabled");
                        if (objResponse != null) {
                            
                            if (objResponse.ResponseStatus != "") {
                                OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                                Reset();
                                GetEInvoiceCredentail();
                            }   
                        }
                    },
                    error: function (xhr, data) {
                        //  return false;
                        console.log(xhr);
                        console.log("Error:", data);
                    }
                });
            }
        });
    });
    function GetEInvoiceCredentail() {
        
        $.ajax({
            url: '/Transaction/GetEInvoiceCredentail',
            type: 'POST',
            dataType: "json",
            success: function (objResponse) {
                if (objResponse != "" || objResponse != null) {
                    ECredentia = [{}];
                    var i = 0;
                    for (i = 0; i < objResponse.length; i++) {
                        var dateObj = new Date(objResponse[i].RectimeStamp.match(/\d+/)[0] * 1);
                        // Extract and format date components
                        var day = String(dateObj.getDate()).padStart(2, '0');
                        var month = String(dateObj.getMonth() + 1).padStart(2, '0'); // Months are zero-based
                        var year = dateObj.getFullYear();

                        // Extract and format time components
                        var hours = String(dateObj.getHours()).padStart(2, '0');
                        var minutes = String(dateObj.getMinutes()).padStart(2, '0');

                        // Combine into the desired format
                        var myDate = `${day}-${month}-${year} ${hours}:${minutes}`;
                        ECredentia.push({
                            "SNo": (i + 1),
                            "Aspid": objResponse[i].Aspid,
                            "ApiPassword": objResponse[i].ApiPassword,
                            "Gstin": objResponse[i].Gstin,
                            "Username": objResponse[i].Username,
                            "EInvPwd": objResponse[i].EInvPwd,
                            "AddDate": myDate,
                            "ActiveStatus": objResponse[i].ActiveStatus
                        })
                    }
                    fillUpperGrid();
                }
            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });
    }
    function fillUpperGrid() {
        if (gridUpper != null) {
            gridUpper.destroy();
            $('#gridUpper').empty();

        }
        gridUpper = $('#gridUpper').grid({
            dataSource: ECredentia,
            uiLibrary: 'bootstrap',
            headerFilter: true,
            columns: [
                { field: 'SNo', width: 80, title: 'S.No.', sortable: true, hidden: false, filterable: false },
                { field: 'Aspid', width: 100, title: 'Aspid', sortable: true, hidden: false, filterable: false },
                { field: 'ApiPassword', width: 80, title: 'Api Password', sortable: true, hidden: false, filterable: false },
                { field: 'Gstin', width: 150, title: 'Gstin', sortable: true, hidden: false, filterable: false },
                { field: 'Username', width: 100, title: 'Username', sortable: true, hidden: false, filterable: false },
                { field: 'EInvPwd', width: 80, title: 'EInv Password', sortable: true, hidden: false, filterable: false },
                { field: 'AddDate', width: 150, title: 'Add Date', sortable: true, hidden: false, filterable: false },
                { field: 'ActiveStatus', width: 100, title: 'Status', sortable: true, hidden: false, filterable: false }
            ],
            pager: { limit: 100, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
        });       
    }
    function Reset()
    {
        $("#Aspid").val('');
        $("#ApiPassword").val('');
        $("#Gstin").val('');
        $("#Username").val('');
        $("#EInvPwd").val('');
    }
    function OpenDialog(dialogId, Message, isConfirmation) {
        if (isConfirmation == "true") {

        }
        else {
            $("#" + dialogId).empty();
            $("#" + dialogId).append('<p>' + Message + '</p>');

            $("#" + dialogId).dialog({
                modal: true,
                buttons: [{
                    text: "OK",
                    id: "btn" + dialogId,
                    click: function () {
                        //var isOpen = $("#dialog").dialog("isOpen");
                        //if (isOpen == true) {
                        //    okCallBack();
                        //}

                        $("#" + dialogId).dialog("close");


                    }
                }]
            });
            $(".ui-dialog-titlebar-close").empty();
            $(".ui-dialog-titlebar-close").append('<i class="fa fa-close"></i>');
        }

    }
</script>
<div class="row">
    <div class="clearfix"></div>
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>Transaction > EInvoice Credential Master</h2>
                    <ul class="nav navbar-right panel_toolbox">
                        <li>
                            <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                        </li>
                    </ul>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">
                    <form id="ECredentialForm" method="post" name="ECredentialForm" onsubmit="false" data-parsley-validate class="validateForm form-horizontal form-label-left">
                        @Html.HiddenFor(m => m.id,new { id = "hid" }) 
                        <div class="col-lg-12">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-4 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Aspid
                                    </label>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.TextBoxFor(m => m.Aspid, new { name = "Aspid", id = "Aspid", maxlength = "18", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-4 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Api Password
                                    </label>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.TextBoxFor(m => m.ApiPassword, new { name = "ApiPassword", id = "ApiPassword", maxlength = "18", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-4 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Gst
                                    </label>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.TextBoxFor(m => m.Gstin, new { name = "Gstin", id = "Gstin", maxlength = "18", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-4 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        Username
                                    </label>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.TextBoxFor(m => m.Username, new { name = "Username", id = "Username", maxlength = "18", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label class="control-label col-lg-4 col-md-3 col-sm-3 col-xs-12" for="category-name">
                                        EInv Password
                                    </label>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.TextBoxFor(m => m.EInvPwd, new { name = "EInvPwd", id = "EInvPwd", maxlength = "18", @class = "form-control col-md-7 col-xs-12" })
                                    </div>
                                </div>
                            </div>
                          
                        </div>
                        <div class="col-lg-12">
                            <button type="submit" style="float:right;" id="SaveProductMasterBtn" class="btn btn-success">Save</button>
                            <div id="dialogMessage" title="Message">

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <table class="table bootstrap-datatable" id="gridUpper"></table>
        </div>
    </div>
</div>