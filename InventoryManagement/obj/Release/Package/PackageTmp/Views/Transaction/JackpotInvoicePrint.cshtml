                            @Model.objListProduct[0].Remarks
                            <br /><br />}
                    </b>
                    @if (Model.IsGSTRegistered == "Y")
                    {
                        <span id="lblVatTax" style="text-decoration:underline; margin-bottom:5px;">Tax Summary</span>

                        <span>  &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</span>

                        <table border="1" cellspacing="0" style="font-size:12px;margin-top:4px;">
                            <tbody>
                                <tr>
                                    <td>Taxable Amt.&nbsp;</td>
                                    @*<td>Tax(%)&nbsp;</td>
                                        <td>Tax Amt.&nbsp;</td>*@
                                    @{
                                        var CheckDate = new DateTime(2017, 7, 1);
                                        if ((CheckDate - Model.BillDate.Date).TotalDays <= 0)
                                        {//means date is greater than 1 july 2017
                                            if (Model.objListProduct[0].TaxType.Trim() == "I")
                                            {
                                                <td>IGST Tax(%)&nbsp;</td>
                                                <td>IGST Tax Amt.&nbsp;</td>
                                            }
                                            else
                                            {
                                                <td>CGST Tax(%)&nbsp;</td>
                                                <td>CGST Tax Amt.&nbsp;</td>
                                                <td>SGST Tax(%)&nbsp;</td>
                                                <td>SGST Tax Amt.&nbsp;</td>
                                            }
                                        }
                                        else
                                        {
                                            <td>Tax(%)&nbsp;</td>
                                            <td>Tax Amt.&nbsp;</td>
                                        }

                                    }


                                    <td>Total Amount</td>
                                </tr>
                                @foreach (var tax in Model.objTaxSummary)
                                {
                                    <tr>
                                        <td>@tax.SumAmount&nbsp;</td>
                                        @*<td>@Model.objProduct.TotalTaxPer &nbsp;</td>
                                            <td>@Model.objProduct.TotalTaxAmount&nbsp;</td>*@
                                        @{
                                            CheckDate = new DateTime(2017, 8, 1);
                                            if ((CheckDate - Model.BillDate.Date).TotalDays <= 0)
                                            {//means date is greater than 1 jult 2017
                                                if (Model.objListProduct[0].TaxType.Trim() == "I")
                                                {

                                                    <td>@tax.SumTaxPer &nbsp;</td>
                                                    <td>@tax.SumTaxAmt&nbsp;</td>

                                                }
                                                else
                                                {
                                                    <td>@tax.SumCGSTPer &nbsp;</td>
                                                    <td>@tax.SumCGSTAmt&nbsp;</td>
                                                    <td>@tax.SumSGSTPer &nbsp;</td>
                                                    <td>@tax.SumSGSTAmt&nbsp;</td>

                                                }
                                            }
                                            else
                                            {
                                                <td>@tax.SumTaxPer &nbsp;</td>
                                                <td>@tax.SumTaxAmt&nbsp;</td>
                                            }

                                        }
                                        <td>@tax.SumNetPayableAmount</td>
                                    </tr>
                                            }

                            </tbody>
                        </table>
                                            }<br />



                    <span id="lblVatTax" style="text-decoration:underline; margin-bottom:5px;">
                        @if (Model.BillType == "J" && Model.NumberOfBill < 7)
                        {
                            <em>
                                Thanks for Shopping.<b>@{ var leftbills = 7 - Model.NumberOfBill; } @leftbills months</b> Left for <b>FREE Jackpot Shopping worth Rs.999/-</b>
                            </em>
                        }
                                    else if (Model.BillType == "X")
                                    {
                                        <em>

                                            <b>Congratulations for Free Shopping worth Rs.@Model.objListProduct[0].VoucherAmt thru Shopping Jackpot Scratch Card.</b>
                                        </em>
                                    }
                    </span>
                    <br /><br />
                  
                </td>

                <td colspan="2" class="removeallborder addRightPadding" style="text-align :right;vertical-align:top ">
                    @if (Model.BillType == "X")
                    {

                        <span id="lblNetPayable" text-align="Right">Total Amount :</span>
                        <span id="lblNetPayabletxt" text-align="Right">@Model.objProduct.TotalNetPayable</span>

                        <br />
                        <div style="width:100%;border-bottom:1px solid #000000; height:5px;margin-bottom:2px;"></div>

                        <b>
                            <span id="lblRoundOff" text-align="Right">SJP Scratch Card No. :</span>
                            <span id="lblRoundOfftxt" text-align="Right">@Model.objListProduct[0].VoucherNo</span>

                            <span id="lblRoundOff" text-align="Right"> Value:</span>
                            <span id="lblRoundOfftxt" text-align="Right">@Model.objListProduct[0].VoucherAmt</span>
                        </b>
                            <br />
                            <span id="lblNetPayable" text-align="Right">Net Payable :</span>
                            <span id="lblNetPayabletxt" text-align="Right">
                                @{
                                    var disc = Math.Round(Convert.ToDouble(Model.objProduct.TotalNetPayable - Model.objListProduct[0].VDiscountAmt));
                                }
                                @disc.00
                            </span>
                        
    <br />
    @*if (Model.IsGSTRegistered == "Y")
        {
            <span id="lblNetPayable" text-align="Right">Add. Tax Amount :</span>
        }
        else
        {
            <span id="lblNetPayable" text-align="Right">Add Misc. FPV charges :</span>
        }
        <span id="lblNetPayabletxt" text-align="Right">@Model.objProduct.TotalTaxAmount</span>

        <br />*@

                                }
                                else
                                {
                                    <b>
                                        <span id="lblNetPayable" text-align="Right">Net Payable :</span>
    <span id="lblNetPayabletxt" text-align="Right">@Model.objListProduct[0].TotalNetPayable</span></b>}


</td>

            </tr>

            @if (Model.objProduct.TotalWeight != null && Model.objProduct.TotalWeight > 0)
            {
                var grossWeight = Model.objProduct.TotalWeight / 1000;
                <tr>
                    <td class="removeborder" colspan="4" style="font-size:12px;">
                        <b>Gross Weight :@grossWeight Kgs (Approx) </b>
                    </td>
                </tr>
            }


            @if (!string.IsNullOrEmpty(Model.Username))
            {
                <tr>
                    <td class="removeborder" colspan="4" style="font-size:12px;">
                        <b>Billed By :@Model.Username </b>
                    </td>
                </tr>
            }
            <tr>

                <td colspan="2" class="removeborder"></td>
                <td colspan="2" class="removeborder" style="text-align :right ">

                    <br />

                </td>
            </tr>
            <tr>
                <td class="removeallborder addLeftPadding" colspan="3" style="font-size:12px;">
                    Terms and Condition :
                    <br />
                    E. & O. E.<br />
                    1. Goods once sold will not be taken back after 30 days and if seal broken.
                    <br />

                    2. All disputes are subject to jurisdiction of @if (!string.IsNullOrEmpty(Model.CompCity))
                    {@Model.CompCity } only.

                    <br />

                    <br />


                    <br />
                    Declaration :
                    <br />

                    1. We declare that this invoice show the actual price of the goods described
                    and that all particulars are true and correct.

                </td>
                <td colspan="2" style="text-align :right;padding-right: 8px;" class="removeallborder">
                    <span id="lblCNMI" align="right">
                        For&nbsp;@if (!string.IsNullOrEmpty(Model.SoldByName))
                        {@Model.SoldByName }
                    </span><br /><br /><br /><br />
                    <span id="lblAuthorisedSign" align="right">Authorised Signatory</span>
                </td>
            </tr>
            <tr>
                <td class="removeallborder"></td>
                <td colspan="4" class="removeallborder" align="right"></td>
            </tr>
            <tr>
                <td colspan="5" class="removeallborder" align="center">
                    @*<span id="lblRegdOffice" align="center" style="font-size:10px;">Regd Office : @if(!string.IsNullOrEmpty(Model.CompanyName)){@Model.CompanyName}, @if (!string.IsNullOrEmpty(Model.CompanyAdd)) { @Model.CompanyAdd}</span>*@
                </td>
            </tr>

        </tbody>
    </table>
    <center><span id="lblRegdOffice" align="center" style="font-size:11px;">This is computer generated invoice, doesn't require signature.</span></center>
