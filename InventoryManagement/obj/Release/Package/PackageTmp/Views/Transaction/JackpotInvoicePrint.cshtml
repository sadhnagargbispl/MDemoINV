    string PVCaption = System.Configuration.ConfigurationManager.AppSettings["PVCaption"];
    string RPCaption = System.Configuration.ConfigurationManager.AppSettings["RPCaption"];
    int count = 1;
    decimal? TotalQty = 0;
    decimal totalMRP = 0;
    decimal? totalBV = 0;
    decimal? totalAmount = 0;
    DateTime checkdtforfreeprod = new DateTime(2020, 02, 26);
}

<link href="~/Content/themes/base/jquery-ui.css" rel="stylesheet" />
<link href="~/Content/jquery-ui-1.10.4.min.css" rel="stylesheet" />
<script src="~/Scripts/jquery-1.12.4.min.js"></script>
<script src="~/Scripts/jquery-1.12.4.js"></script>
<style>
    body {
        font-family: Verdana;
    }

    th {
        font-size: 12px;
    }

    .gj-grid-wrapper {
        min-width: 100% !important;
        overflow-x: scroll !important;
    }

    .spanAddress {
        width: 70%;
        display: inline-block;
        word-wrap: break-word;
    }

    .addPadding {
        padding-left: 0.5% !important;
        padding-right: 0.5% !important;
    }

    .addAllPadding {
        padding-left: 0.5% !important;
        padding-right: 0.5% !important;
        padding-top: 0.5% !important;
        padding-bottom: 0.5% !important;
    }

    .addLeftPadding {
        padding-left: 0.5% !important;
    }

    .addRightPadding {
        padding-right: 0.5% !important;
    }

    .fontStyle {
        font-family: Verdana !important;
        font-size: 12px !important;
        font-weight: bold !important;
    }

    .removeborder {
        border-left: none !important;
        border-bottom: none !important;
        border-right: none !important;
    }

    .removeexceptleft {
        border-bottom: none !important;
        border-right: none !important;
        border-top: none !important;
    }

    .removeallborder {
        border-style: none !important;
        border-color: inherit !important;
        border-width: medium !important;
        margin-left: 120px !important;
    }

    .rightBorderOnly {
        border-right: none !important;
        border-bottom: none !important;
    }

    .fontHeader {
        font-family: Verdana !important;
        font-size: 14px !important;
        text-align: center !important;
    }

    .Grid {
        height: 500px;
        overflow-y: scroll;
    }

    .gridalign {
        text-align: center;
    }

    .gridleftalign {
        text-align: left;
    }
</style>
<script type="text/javascript">

    function printPageElement() {
        var url = window.location.href;

        var mywindow = window.open('', 'PRINT', 'height=400,width=600');
        console.log("mywindow", mywindow);
        var PrintHtml = $("#DivToPrint").html();

        mywindow.document.write(PrintHtml);


        mywindow.document.close(); // necessary for IE >= 10
        mywindow.focus(); // necessary for IE >= 10*/

        mywindow.print();
        mywindow.close();

        return true;
    }
    $(document).ready(function () {
        $(".preloader").hide();
    });
</script>
<div id="DivToPrint" class="fontStyle">
    <div>
        <button id="PrintPage" style="margin-left: 2%;" onclick="printPageElement()">Print</button>
        <br />
    </div>
    <div>&nbsp;</div>
    <table border="1" align="center" cellspacing="0" id="InvoicePrint">
        <tbody>
            <tr align="center">

                <td colspan="5" class="removeborder">
                    <table border="0" style="width:100%">
                        <tbody>

                            <tr align="left" class="fontHeader ">
                                <td rowspan="3" width="20%"><img src="~/images/sp.png" style="height:135px;"/></td>
                                <td width="70%">
                                    @if (Model.IsGSTRegistered == "Y")
                                    {
                                        <b> GST Invoice</b>
                                    }
                                    else
                                    {
                                        <b> Invoice</b>
                                    }
                                    <br />
                                    <span id="lblOfficeName" align="Center" style="display:inline-block;height:30px;font-size:20px;">
                                        <b>
                                            @if (!string.IsNullOrEmpty(Model.SoldByName))
                                            {@Model.SoldByName }
                                        </b>
                                    </span>
                                </td>
                                <td rowspan="3" width="10%"></td>
                            </tr>
                            <tr align="left" class="fontHeader ">
                                <td>
                                    <span id="lblAddressTop" align="Center" style="display:inline-block;height:32px;">
                                        @if (!string.IsNullOrEmpty(Model.SoldByAddress))
                                        {@Model.SoldByAddress}
                                    </span>
                                </td>
                            </tr>
                            <tr class="fontHeader">

                                @if (Model.IsGSTRegistered == "Y")
                                {
                                    <td class="addLeftPadding">
                                        <br />
