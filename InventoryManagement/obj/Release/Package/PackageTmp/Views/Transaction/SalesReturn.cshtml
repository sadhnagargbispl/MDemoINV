                });
            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });
    }

    function GetBillDetails(BillNo) {
        ProductGrid = [];
        $.ajax({
            url: '@Url.Action("GetBillDetail", "Transaction")',
            type: 'GET',
            data: { BillNo },
            dataType: "json",
            success: function (objResult) {

                var nowDate = new Date(parseInt(objResult.BillDate.substr(6)));
                $('#BillDate').val(nowDate.format("dd/mm/yyyy"));
                $('#returnto').val(objResult.SoldBy);
                $('#PartyCode').val(objResult.partyCode);
                $('#PartyName').val(objResult.partyName);
               
                $(objResult.ProductList).each(function () {
                    ProductGrid.push({ "PVValue": this.PVValue, "CVValue": this.CVValue, "CommissionAmt": this.CommissionAmt, "CommissionPer": this.CommissionPer, "CV": this.CV, "PV": this.PV, "ProdStateCode": this.ProdStateCode, "DiscAmt": this.DiscAmt, "DiscPer": this.DiscPer, "DP": this.DP, "BarCode": this.Barcode, "ProductName": this.ProductName, "BatchNo": this.BatchNo, "ProdCode": this.ProductCodeStr, "MRP": this.MRP, "Rate": this.Rate, "ReturnQty": this.ReturnQty, "GST": this.GSTPer, "Amount": 0, "TaxAmount": 0, "TotalAmount": 0, "BV": this.BV, "BVValue": 0, "RP": this.RP, "RPValue": 0, "OrderedQty": this.Quantity });
                });

                FillGrid();
            },
            error: function (xhr, data) {
                //  return false;
                console.log(xhr);
                console.log("Error:", data);
            }
        });
    }

   function FillGrid() {

        if (uppergrid != null) {
            uppergrid.destroy();
            $('#grid').empty();

        }

        uppergrid = $('#grid').grid({
            dataSource: ProductGrid,
            uiLibrary: 'bootstrap',
            headerFilter: true,
            columns: [
                    { field: 'BarCode', width: 80, title: 'BarCode', sortable: false, hidden: false, filterable: false },
                    { field: 'ProductName', width: 100, title: 'Product Name', sortable: false, hidden: false, filterable: false },
                    { field: 'BatchNo', width: 100, title: 'Batch No.', sortable: false, hidden: false, filterable: false },
                    { field: 'ProdCode', width: 80, title: 'Product Code', sortable: false, hidden: false, filterable: false },
                    { field: 'MRP', width: 80, title: 'MRP', sortable: false, hidden: false, filterable: false },
                    { field: 'Rate', width: 80, title: 'Rate', sortable: false, hidden: false, filterable: false },
                    { field: 'ReturnQty', width: 80, title: 'Return Qty', sortable: false, hidden: false, filterable: false },
                    { field: 'StockAvailable', width: 80, title: 'StockAvailble', sortable: false, hidden: true, filterable: false },
                    { field: 'TaxPer', width: 80, title: 'Tax(%)', sortable: false, hidden: false, filterable: false },
                    { field: 'Amount', width: 80, title: 'Amount', sortable: false, hidden: false, filterable: false },
                    { field: 'TaxAmount', width: 80, title: 'Tax Amount', sortable: false, hidden: false, filterable: false },
                    { field: 'TotalAmount', width: 80, title: 'Total Amount', sortable: false, hidden: false, filterable: false },
                    { field: 'BV', width: 80, title: '@BVCaption', sortable: false, hidden: false, filterable: false },
                    { field: 'BVValue', width: 80, title: '@BVCaption Value', sortable: false, hidden: false, filterable: false },
                    { field: 'RP', width: 80, title: '@RPCaption', sortable: false, hidden: true, filterable: false },
                    { field: 'RPValue', width: 80, title: '@RPCaption Value', sortable: false, hidden: true, filterable: false },
            ],
            pager: { limit: 20, sizes: [15, 20, 35, 50, 65, 80, 95, 100] }
        });
        uppergrid.on('rowSelect', function (e, $row, id, record) {
            IsAnyProductReturn = false;
            fillProductValues(record,true);
            openEditPopup();
        });
    }
</script>

