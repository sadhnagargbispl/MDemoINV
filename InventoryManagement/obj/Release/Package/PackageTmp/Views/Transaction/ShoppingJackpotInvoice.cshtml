        function GetCustomerInfo(IdNo) {
            $.ajax({
                url: '@Url.Action("GetSJPCustInfo", "Transaction")',
                type: 'POST',
                data: { "IdNo": IdNo },

                dataType: "json",
                success: function (objResult) {
