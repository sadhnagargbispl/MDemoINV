        $("#SaveDistributorForm").click(function (e) {
            $("#SaveDistributorForm").attr("disabled", true);            
            
            var NetpayableValue = $("#NetPayable").val();
            if (NetpayableValue != null && NetpayableValue != "") {
                NetpayableValue = parseFloat(NetpayableValue);
            }
            else {
                NetpayableValue = 0;
            }
           
            var NetAmountError = false;                     
            var Id = $("#IdNo").val();
            var TotalBV = $("#TotalBV").val();
            var TotalQty = $("#TotalQty").val();
            var IsFirstBill = $("#FirstBill").val() == "true" ? true : false;

            if (NetpayableValue < 999)
            {
                NetAmountError = true;
            }

            if (NetAmountError == false) {

                if (ProductGrid != null) {
                    if (ProductGrid[0].SNo == "" || ProductGrid[0].SNo == null || ProductGrid[0].SNo == undefined) {
                        ProductGrid = ProductGrid.splice(1);
                    }
                }
                
                if (ProductGrid.length > 0) {
                    e.preventDefault();
                    e.stopPropagation();
                    var ListObjStr = JSON.stringify(ProductGrid);
                    $("#ListObjHidden").val(ListObjStr);
                    formdata = new FormData($("#distributorForm")[0]);
                    SaveBill();
                }
                else {
                    $("#SaveDistributorForm").attr("disabled", false);
                    OpenDialog("dialogMessage", "There should be atleast one product in grid", "false");
                }

            }
            else {
                $("#SaveDistributorForm").attr("disabled", false);
                if (NetAmountError)
                    OpenDialog("dialogMessage", "Bill amount should be greater than or equal to 999/-", "false");
               
            }
        });


        function SaveBill() {
            $("#BillType").val("J");
            formdata = new FormData($("#distributorForm")[0]);
            $.ajax({
                url: '@Url.Action("SaveDistributorBill", "Transaction")',
                type: 'POST',
                data: formdata,
                processData: false,
                contentType: false,
                dataType: "json",
                success: function (objResponse) {
                    $("#SaveDistributorForm").attr("disabled", false);
                    if (objResponse != null) {

                        if (objResponse.ResponseStatus == "OK") {
                            var BillNo = objResponse.ResponseDetailsToPrint.BillNo;
                            var SoldBy = objResponse.ResponseDetailsToPrint.SoldBy;
                            openBill(BillNo, SoldBy);
                            window.location.href = '@Url.Action("ShoppingJackpotInvoice", "Transaction")';
                        }
                        else {
                            OpenDialog("dialogMessage", objResponse.ResponseMessage, "false");
                        }
                    }
                },
                error: function (xhr, data) {
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });
        }

        

        function openBill(billNo, soldBy) {
            var url = '@Url.Action("InvoicePrint", "Transaction",new {Pm="-1"})';
            var encodedparameters = billNo;
            var EncryptedB64Url = window.btoa(encodedparameters);
            url = url.replace("-1", EncryptedB64Url);
            var win = window.open(url, '_blank');       
        }
    });
