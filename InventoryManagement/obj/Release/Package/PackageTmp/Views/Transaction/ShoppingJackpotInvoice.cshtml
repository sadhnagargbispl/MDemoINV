                            $("#FormNo").val(objResult.FormNo);
                            $("#IdNo").val(objResult.IdNo);
                            $("#Name").val(objResult.Name);
                            
                            $("#IsBillOnMrp").val(objResult.IsBillOnMrp);
                            $("#FirstBill").val(objResult.IsFirstBill);

                            $("#StateCode").val(objResult.StateCode);
                            MinBV4upgrade = objResult.MinBillAmt;
                            $("#MinRepurch").val(objResult.MinRepurch);
                            $("#MaxBV").val(objResult.MaxBV);
                            $("#Doj").val(objResult.Doj);
                            $("#UpgradeDate").val(objResult.UpgradeDate);

                            
                            var r = objResult.InvoiceType;
                            var f = true;
                            $("#SelectedInvoiceType").empty();
                            if (r.length > 0) {
                                for (var i = 0; i < r.length; i++) {
                                    var splitInvoiceValue = r[i].split(",");                                   
                                    $("#SelectedInvoiceType").append("<option value=" + splitInvoiceValue[1] + ">" + splitInvoiceValue[0] + "</option>");
                                }
                            }
                            else {
                                $("#hiddenSelectedInvoiceType").val(0);
                                $("#SelectedInvoiceType").append("<option value='0'>--No Type Found--</option>");
                            }
                           
                            $("#MinBillAmt").val(objResult.MinBillAmt);                            
                            $("#AvailBal").val(objResult.WalletBalance);
                            $("#AmountByWallet").val(0);
                            $("#RemBal").val(objResult.WalletBalance);
                            $("#MobileNo").val(objResult.MobileNo);
                            $("#NumberOfBill").val(objResult.MobileNo);
                            if (objResult.NumberOfBill == 7) {
                                $("#DiscountBillMessage").html("7th Month Free Shopping benefit: 999/-");
                                $("#CashDiscAmount").val(999);
                            }
                            else {
                                $("#DiscountBillMessage").html("");
                                $("#CashDiscAmount").val(0);
                            }
                        }
                    }
                    else {
                        //$("#IdNo").focus();
                        $("#FormNo").val(0);
                        $("#IdNo").val('');
                        $("#Name").val('');
                        // $("#Address").val('');
                        $("#ReferenceIdNo").val('');
                        $("#ReferenceName").val('');
                        $("#Address").val('');
                        $("#IsBillOnMrp").val(false);
                        $("#MinRepurch").val(0);
                        $("#FirstBill").val(false);
                        OpenDialog("dialogMessage", "Record Does Not Exists", "false");

                    }

                    ResetDetails();
                },
                error: function (xhr, data) {
                    //  return false;
                    console.log(xhr);
                    console.log("Error:", data);
                }
            });

        }

        

        function GetProductInfo(isProductSearch, data, offerProduct, offerQty) {
            debugger;
            var dataValue = data;
            var getInfo = true;
            var IsBillOnMrp = $("#IsBillOnMrp").val();
            var OfferType = parseFloat($("#OfferType").val());
            var index = OfferItemList.indexOf(data);
            var offerID = 0;
            var IsSpclOffer = false;
            var SpclOffer = parseFloat($("#SpclOffer").val());
            
            offerID = 0;
            IsOfferProduct = false;
            IsBillOnMrp = true;
            IsSpclOffer = false;


            if (getInfo && (isProductSearch == "P" || isProductSearch == "B")) {
                if (isProductSearch == "B") {
                    dataValue = $("#Barcode").val();
                }
                if (dataValue != "" && dataValue != null && dataValue != undefined) {
                    $.ajax({
                        url: '@Url.Action("GetProductInfo", "Transaction")',
                        type: 'POST',
                        async: false,
                        data: { "SearchType": isProductSearch, "data": dataValue, "isCForm": false, "BillType": "distributor", "IsBillOnMrp": IsBillOnMrp, "OfferID": offerID, "StockforParty": null, "allhalf": false, "IsSpclOffer": IsSpclOffer },
                        dataType: "json",
                        success: function (objResult) {
                            if (objResult != null && objResult.length > 0) {
                                //fill values
                                var PFlag = true;
                                if (objResult[0].IsAvailableForBilling == "N" && objResult[0].IsAvailableForOffer == "Y") {
                                    if (index == -1) {
                                        PFlag = false;
                                    }
                                }
                                if (PFlag == true) {
                                    ProductSearchList = null
                                    IsCommissionAdd = objResult[0].IsCommissonAdd;
                                    IsDiscountAdd = objResult[0].IsDiscountAdd;
                                    ProductSearchList = objResult;
                                    $("#ProductNameList").empty();
                                    $("#BarcodeList").empty();

                                    AvailableProductList = [{}];
                                    if (isProductSearch == "P") {
                                        if (AvailableBarcodeList != null && AvailableBarcodeList.length > 0) {
                                            AvailableBarcodeList = $.grep(AvailableBarcodeList, function (e) {
                                                return e.ProductName != objResult[0].ProductName;
                                            });
                                        }
                                        $("#ProductName").val(objResult[0].ProductName);
                                        $("#ProductHidden").val(objResult[0].ProductName);
                                        var f = true;
                                        for (var i = 0; i < objResult.length; i++) {
                                            //if (f == true) {
                                            //    f = false;
                                            $("#BarcodeHidden").val(objResult[i].Barcode);
                                            // }
                                            if (IsOfferProduct == false) {
                                                AvailableBarcodeList.push({ "ProductName": objResult[i].ProductName, "BarCode": objResult[i].Barcode });
                                            }
                                            else {
                                                AvailableBarcodeList.push({ "ProductName": objResult[i].ProductName, "BarCode": objResult[i].Barcode });
                                                break;
                                            }
                                        }

                                        fillBarcodeList(objResult[0].ProductName);
                                    }
                                    if (isProductSearch == "B") {
                                        $("#Barcode").val(objResult[0].Barcode);
                                        $("#BarcodeHidden").val(objResult[0].Barcode);
                                        var f = true;
                                        for (var i = 0; i < objResult.length; i++) {
                                            if (f == true) {
                                                f = false;
                                                $("#ProductHidden").val(objResult[i].ProductName);

                                            }
                                            AvailableProductList = AvailableProductList.splice(1);
                                            AvailableProductList.push({ "ProdCode": objResult[i].ProductCodeStr, "ProductName": objResult[i].ProductName });
                                            $("#ProductNameList").append("<option value=" + objResult[i].ProductCodeStr + ">" + objResult[i].ProductName + "</option>");
                                        }

                                    }

                                    fillProductValues(objResult[0], offerProduct, offerQty, IsSpclOffer);
                                }
                                else {
                                    OpenDialog("dialogMessage", "You can select this product only with a valid offer.", "false");
                                    ClearProductdetailsWithoutChangingValues();
                                    return;
                                }
                            }
                            else {
                                OpenDialog("dialogMessage", "No Product Found!", "false");
                                //$("#ProductName").val("");

                                ClearProductdetailsWithoutChangingValues();
                            }
                        },
                        error: function (xhr, data) {
                            //  return false;
                            console.log(xhr);
                            console.log("Error:", data);
                        }
                    });
                }

            }
        }
        $("#ProductNameList").change(function () {
            var SelectedVal = $("#ProductNameList").val()
